---
// Shared shell for the Vibecamp Trials pages: theme, aurora, crumbs nav, footer.
// Pages provide their hero + content via the slot.
const {
  title,
  description,
  crumbs = [
    { href: "/", label: "← Vibecamp home" },
    { href: "/schedule/", label: "Event schedule →" },
  ],
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/vibecamp_logo.png" />
    <link rel="apple-touch-icon" href="/vibecamp_logo.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://vibecamp.mahan.io/vibecamp_logo.png" />
    <meta name="twitter:card" content="summary" />
    <script is:inline>
      // set theme before first paint to avoid a flash of the wrong palette
      (function () {
        var t = "system";
        try { t = localStorage.getItem("vc-theme") || "system"; } catch (e) {}
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
  </head>
  <body>
    <div class="aurora"></div>

    <nav class="crumbs">
      {crumbs.map((c) => <a href={c.href}>{c.label}</a>)}
    </nav>

    <main class="trials">
      <slot />
    </main>

    <footer class="trials-foot">
      <nav class="t-icons" aria-label="The Trials badges">
        <a href="/trials/badges/" title="See the badges in 3D">
          <img src="/trials/icons/logo-map-territory.png" alt="Map badge icon" loading="lazy" />
          <img src="/trials/icons/logo-mpot-ypot.png" alt="Bird badge icon" loading="lazy" />
          <img src="/trials/icons/logo-ycjdt-take-me.png" alt="Take Me badge icon" loading="lazy" />
          <img src="/trials/icons/logo-post-rat.png" alt="Rat badge icon" loading="lazy" />
          <img src="/trials/icons/logo-friendly-ambitious-nerds.png" alt="Puzzle badge icon" loading="lazy" />
        </a>
      </nav>
      <p>Send bugs to <a href="https://twitter.com/timebard" target="_blank" rel="noopener">@timebard</a> on twitter!</p>
    </footer>

    <style is:global>
      /* --- dark (Catppuccin Mocha) — the default --- */
      :root {
        color-scheme: dark;
        --base: #1e1e2e; --mantle: #181825; --crust: #11111b;
        --surface0: #313244; --surface1: #45475a; --surface2: #585b70;
        --overlay0: #6c7086; --overlay1: #7f849c; --overlay2: #9399b2;
        --text: #cdd6f4; --subtext1: #bac2de; --subtext0: #a6adc8;
        --blue: #89b4fa; --lavender: #b4befe; --sapphire: #74c7ec;
        --sky: #89dceb; --teal: #94e2d5; --green: #a6e3a1;
        --yellow: #f9e2af; --peach: #fab387; --maroon: #eba0ac;
        --red: #f38ba8; --mauve: #cba6f7; --pink: #f5c2e7;
        --card: rgba(24,24,37,.66);
        --cork1: #6b4f33; --cork2: #58412a; --cork-frame: #4a3520;
        --hand: "Segoe Print", "Bradley Hand", "Comic Sans MS", cursive;
      }
      :root[data-theme="light"],
      :root[data-theme="system"] { color-scheme: light dark; }
      @media (prefers-color-scheme: light) {
        :root[data-theme="system"] {
          color-scheme: light;
          --base: #eff1f5; --mantle: #e6e9ef; --crust: #dce0e8;
          --surface0: #ccd0da; --surface1: #bcc0cc; --surface2: #acb0be;
          --overlay0: #9ca0b0; --overlay1: #8c8fa1; --overlay2: #7c7f93;
          --text: #4c4f69; --subtext1: #5c5f77; --subtext0: #6c6f85;
          --blue: #1e66f5; --lavender: #7287fd; --sapphire: #209fb5;
          --sky: #04a5e5; --teal: #179299; --green: #40a02b;
          --yellow: #df8e1d; --peach: #fe640b; --maroon: #e64553;
          --red: #d20f39; --mauve: #8839ef; --pink: #ea76cb;
          --card: rgba(230,233,239,.78);
          --cork1: #c49a68; --cork2: #b18a5b; --cork-frame: #7c5c38;
        }
      }
      :root[data-theme="light"] {
        color-scheme: light;
        --base: #eff1f5; --mantle: #e6e9ef; --crust: #dce0e8;
        --surface0: #ccd0da; --surface1: #bcc0cc; --surface2: #acb0be;
        --overlay0: #9ca0b0; --overlay1: #8c8fa1; --overlay2: #7c7f93;
        --text: #4c4f69; --subtext1: #5c5f77; --subtext0: #6c6f85;
        --blue: #1e66f5; --lavender: #7287fd; --sapphire: #209fb5;
        --sky: #04a5e5; --teal: #179299; --green: #40a02b;
        --yellow: #df8e1d; --peach: #fe640b; --maroon: #e64553;
        --red: #d20f39; --mauve: #8839ef; --pink: #ea76cb;
        --card: rgba(230,233,239,.78);
        --cork1: #c49a68; --cork2: #b18a5b; --cork-frame: #7c5c38;
      }

      * { box-sizing: border-box; }
      html, body { height: 100%; overflow-x: clip; }
      body {
        margin: 0; background: var(--base); color: var(--text);
        font-family: "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        line-height: 1.5; -webkit-font-smoothing: antialiased;
        display: flex; flex-direction: column;
      }
      .aurora {
        position: fixed; inset: 0; z-index: -1;
        background:
          radial-gradient(55% 45% at 12% 0%, rgba(249,226,175,.14), transparent 70%),
          radial-gradient(50% 40% at 92% 4%, rgba(203,166,247,.16), transparent 70%),
          radial-gradient(60% 50% at 50% 100%, rgba(148,226,213,.10), transparent 70%);
      }

      .crumbs {
        display: flex; justify-content: space-between; gap: 1rem;
        max-width: 880px; width: 100%; margin: 0 auto; padding: 1.2rem 1.5rem 0;
      }
      .crumbs a { color: var(--blue); text-decoration: none; font-size: .92rem; font-weight: 600; }
      .crumbs a:hover { text-decoration: underline; }

      .trials {
        flex: 1; width: 100%; max-width: 880px; margin: 0 auto;
        padding: 2.6rem 1.5rem 2rem; text-align: center;
        display: flex; flex-direction: column; gap: 2rem;
      }
      .kicker { margin: 0 0 .5rem; font-size: .85rem; letter-spacing: .28em; text-transform: uppercase; color: var(--mauve); font-weight: 600; }
      .trials-hero h1 {
        margin: 0; font-size: clamp(2.2rem, 6vw, 3.4rem); letter-spacing: -.02em;
        background: linear-gradient(120deg, var(--yellow), var(--peach) 55%, var(--mauve));
        -webkit-background-clip: text; background-clip: text; color: transparent;
      }
      .trials-sub { margin: .6rem 0 0; color: var(--subtext0); font-size: 1.05rem; }
      .spark { color: var(--yellow); -webkit-text-fill-color: var(--yellow); animation: spin-spark 3s ease-in-out infinite; display: inline-block; }
      .spark.s2 { animation-delay: 1.5s; }
      @keyframes spin-spark {
        0%, 100% { transform: scale(.8) rotate(0deg); opacity: .7; }
        50%      { transform: scale(1.15) rotate(35deg); opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) { .spark { animation: none; } }

      /* the cork message board */
      .board {
        position: relative; border-radius: 8px;
        padding: 2.4rem 1.8rem 2.2rem;
        background:
          radial-gradient(rgba(0,0,0,.16) 1px, transparent 1.5px),
          radial-gradient(rgba(255,236,200,.06) 1px, transparent 1.6px),
          radial-gradient(rgba(0,0,0,.10) 1.3px, transparent 1.9px),
          linear-gradient(135deg, var(--cork1), var(--cork2));
        background-size: 9px 11px, 15px 17px, 22px 19px, 100% 100%;
        background-position: 0 0, 5px 8px, 11px 3px, 0 0;
        border: 10px solid var(--cork-frame);
        box-shadow:
          inset 0 2px 18px rgba(0,0,0,.45),
          inset 0 0 0 2px rgba(0,0,0,.2),
          0 14px 38px rgba(17,17,27,.4);
        /* rasterize the cork gradients once on their own compositor layer —
           otherwise everything animating over them repaints the texture per frame */
        transform: translateZ(0);
      }
      @media (max-width: 640px) { .board { padding: 2rem 1rem 1.8rem; border-width: 8px; } }

      /* anything .pinned hangs on the board with a pushpin and a slight tilt */
      .pinned { position: relative; transform: rotate(var(--tilt, 0deg)); }
      .pinned::before {
        content: ""; position: absolute; top: -8px; left: 50%; margin-left: -8px;
        width: 16px; height: 16px; border-radius: 50%;
        background: radial-gradient(circle at 35% 30%,
          color-mix(in srgb, var(--ac, var(--red)) 45%, white),
          var(--ac, var(--red)) 55%,
          color-mix(in srgb, var(--ac, var(--red)) 55%, black));
        box-shadow: 0 3px 4px rgba(0,0,0,.45), inset 0 -1px 2px rgba(0,0,0,.3);
        z-index: 2;
      }
      .board .t-prose h2, .board .doc-head h2 { font-family: var(--hand); }

      /* a scrawled sticky note on the board */
      .sticky {
        width: max-content; max-width: 80%;
        margin: 1.4rem auto 0; padding: .7rem 1.1rem .85rem;
        background: linear-gradient(160deg, #f7e7a8, #efd989);
        color: #43381c; font-family: var(--hand); font-size: .95rem; line-height: 1.35;
        transform: rotate(2deg);
        box-shadow: 0 6px 16px rgba(0,0,0,.35);
        border-bottom-right-radius: 60% 12px;
      }

      /* link cards (the hub) — flyers pinned at slight angles */
      .t-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem 1.2rem; }
      @media (max-width: 640px) { .t-cards { grid-template-columns: 1fr; } }
      .t-card {
        position: relative; text-decoration: none; color: var(--text);
        background: var(--card); border: 1px solid var(--surface0); border-radius: 1rem;
        padding: 1.7rem 1.3rem 1.3rem; text-align: left;
        display: flex; flex-direction: column; gap: .5rem;
        transform: rotate(var(--tilt, 0deg));
        transition: transform .18s, box-shadow .18s, border-color .18s;
      }
      .t-card::before {
        content: ""; position: absolute; top: -8px; left: 50%; margin-left: -8px;
        width: 16px; height: 16px; border-radius: 50%;
        background: radial-gradient(circle at 35% 30%,
          color-mix(in srgb, var(--ac, var(--yellow)) 45%, white),
          var(--ac, var(--yellow)) 55%,
          color-mix(in srgb, var(--ac, var(--yellow)) 55%, black));
        box-shadow: 0 3px 4px rgba(0,0,0,.45), inset 0 -1px 2px rgba(0,0,0,.3);
        z-index: 2;
      }
      .t-card:hover, .t-card:focus-visible {
        transform: rotate(0deg) translateY(-5px) scale(1.02);
        box-shadow: 0 16px 42px color-mix(in srgb, var(--ac, var(--yellow)) 18%, rgba(17,17,27,.5));
        border-color: var(--ac, var(--yellow));
      }
      .t-card-emoji {
        font-size: 2.1rem; line-height: 1; width: max-content;
        transform: rotate(-8deg); filter: drop-shadow(0 3px 6px rgba(17,17,27,.4));
        transition: transform .18s;
      }
      .t-card:hover .t-card-emoji { transform: rotate(6deg) scale(1.12); }
      .t-card-title { font-family: var(--hand); font-size: 1.25rem; font-weight: 700; }
      .t-card-desc { color: var(--subtext0); font-size: .92rem; }
      .t-card-go { margin-top: auto; padding-top: .5rem; color: var(--ac, var(--yellow)); font-weight: 600; font-size: .92rem; font-family: var(--hand); }
      .t-card-wide { grid-column: 1 / -1; }
      @media (prefers-reduced-motion: reduce) { .t-card, .t-card-emoji { transition: none; } }

      /* prose card (about / documents / hints content) */
      .t-prose {
        background: var(--card); border: 1px solid var(--surface0); border-radius: 1rem;
        padding: 2rem 1.8rem; max-width: 680px; margin: 0 auto; text-align: left;
      }
      .t-prose h2 { margin: 0 0 1rem; font-size: 1.35rem; color: var(--yellow); }
      .t-prose p { margin: 0 0 1rem; color: var(--subtext1); }
      .t-prose p:last-child { margin-bottom: 0; }
      .t-prose a { color: var(--blue); }
      .t-prose .muted { color: var(--overlay1); font-size: .9rem; }

      /* paper variant — anything pinned to the cork reads as ink on paper */
      .t-prose.paper, .t-card.paper {
        background: linear-gradient(178deg, var(--p1, #f5efe0), var(--p2, #ebe2cc));
        border: none; border-radius: 2px;
        box-shadow: 0 10px 24px rgba(0,0,0,.45);
        color: #443e30;
      }
      .t-prose.paper h2 { color: #5b3a16; }
      .t-prose.paper p { color: #443e30; }
      .t-prose.paper a { color: #2a5db0; }
      .t-prose.paper .muted { color: #8d8169; }
      .t-card.paper .t-card-title { color: #2f2a20; }
      .t-card.paper .t-card-desc { color: #6f6550; }
      .t-card.paper .t-card-go { color: color-mix(in srgb, var(--ac, #8a6210) 55%, #2f2a20); }
      .t-card.paper:hover, .t-card.paper:focus-visible { border: none; outline: 2px solid var(--ac, var(--yellow)); outline-offset: 2px; }

      .trials-foot { padding: 1.4rem 1.5rem 2.4rem; text-align: center; }
      .trials-foot p { margin: 0; font-size: .82rem; color: var(--overlay0); }
      .trials-foot a { color: var(--blue); }

      /* badge-icon strip: black engrave art → inverted to glow on the dark theme */
      .t-icons { margin-bottom: 1rem; }
      .t-icons a { display: inline-flex; gap: 1.1rem; align-items: center; }
      .t-icons img {
        height: 30px; width: auto;
        filter: invert(.88) opacity(.55);
        transition: filter .15s, transform .15s;
      }
      .t-icons a:hover img { filter: invert(.88) opacity(.95); transform: translateY(-2px); }
      :root[data-theme="light"] .t-icons img { filter: opacity(.5); }
      :root[data-theme="light"] .t-icons a:hover img { filter: opacity(.9); }
      @media (prefers-color-scheme: light) {
        :root[data-theme="system"] .t-icons img { filter: opacity(.5); }
        :root[data-theme="system"] .t-icons a:hover img { filter: opacity(.9); }
      }
      @media (max-width: 480px) { .t-icons img { height: 22px; } .t-icons a { gap: .7rem; } }
    </style>
  </body>
</html>
