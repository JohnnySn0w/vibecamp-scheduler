      const setSheen = () => document.documentElement.style.setProperty("--sheenx", (-scroll.scrollLeft * 0.6) + "px");
      scroll.addEventListener("scroll", setSheen, { passive: true });
      setSheen();

      // ---- mobile: fade the schedule bar in on first downscroll, then keep it shown ----
      const trayMQ = window.matchMedia("(max-width: 560px)");
      let trayRevealed = false;
      const maybeRevealTray = () => {
        if (trayRevealed || !trayMQ.matches) return;
        if (window.scrollY > 60) { tray.classList.add("revealed"); trayRevealed = true; }
      };
      window.addEventListener("scroll", maybeRevealTray, { passive: true });
      maybeRevealTray();

      // ---- mobile: minimize/drawer toggle for the schedule bar ----
      const trayToggle = document.getElementById("tray-toggle");
      function updateTrayToggle() {
        const collapsed = tray.classList.contains("collapsed");
        trayToggle.textContent = collapsed ? "▾" : "▴";
        trayToggle.setAttribute("aria-label", collapsed ? "Open schedule bar" : "Minimize schedule bar");
      }
      trayToggle.addEventListener("click", () => { tray.classList.toggle("collapsed"); updateTrayToggle(); });
      updateTrayToggle();

      // ---- sparkles inside "Vibecamp Trials" — it's Michael's event, so it's special ----
      // The bar is very wide AND (in Row view) a background layer beneath the foreground
      // events, so sparkles drawn into it get occluded. Instead we draw them into a
      // transparent, click-through overlay that mirrors the bar's box but stacks on top.
      // The overlay's overflow:hidden keeps every sparkle inside the bar's bounds.
      (function sparkleTrials() {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const host = document.querySelector(".bar.trials");
        if (!host) return;
        const scrollEl = document.getElementById("scroll");
        const ov = document.createElement("div");
        ov.className = "spark-overlay";
        host.offsetParent.appendChild(ov);    // sibling of the bars, inside .lanes
        const GLYPHS = ["✦", "✧", "⋆", "✶", "·"];
        setInterval(() => {
          const hidden = host.classList.contains("dim") || host.style.display === "none";
          ov.style.display = hidden ? "none" : "";
          if (hidden) return;
          // keep the overlay aligned to the bar (geometry shifts on zoom / view change)
          ov.style.left = host.offsetLeft + "px"; ov.style.top = host.offsetTop + "px";
          ov.style.width = host.offsetWidth + "px"; ov.style.height = host.offsetHeight + "px";
          const br = host.getBoundingClientRect(), sr = scrollEl.getBoundingClientRect();
          const visL = Math.max(br.left, sr.left), visR = Math.min(br.right, sr.right);
          if (visR - visL < 8 || br.bottom < sr.top || br.top > sr.bottom) return; // off-screen
          const localL = visL - br.left, localR = visR - br.left;
          const burst = 2 + Math.floor(Math.random() * 2);   // 2-3 sparkles per tick
          for (let k = 0; k < burst; k++) {
            const s = document.createElement("span");
            s.className = "sparkle";
            s.textContent = GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
            s.style.left = (localL + Math.random() * (localR - localL)) + "px";
            s.style.top = (3 + Math.random() * Math.max(1, host.offsetHeight - 13)) + "px";
            s.style.fontSize = (0.55 + Math.random() * 0.55) + "rem";
            ov.appendChild(s);
            s.addEventListener("animationend", () => s.remove(), { once: true });
          }
        }, 150);
      })();
      // (vertical wheel is left to scroll the page — the schedule is tall, so we no
      //  longer hijack vertical scroll into horizontal. Trackpad/shift+wheel still
      //  scroll the timeline horizontally natively, and drag-to-scroll works on desktop.)
    </script>

