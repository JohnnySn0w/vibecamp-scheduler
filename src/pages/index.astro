---
import events from "../events.json";

// ---- geometry config ----
const PX_PER_MIN = 2.6;
const LANE_H = 46;
const LANE_GAP = 8;
const MIN_BAR = 66;
const DAY_GAP = 76;     // gap between days on the continuous axis
const SIDE_PAD = 16;
const VENUE_GAP = 12;   // vertical gap between venue rows

const BAR_COLORS = [
  "#89b4fa", "#cba6f7", "#a6e3a1", "#fab387", "#89dceb",
  "#f5c2e7", "#94e2d5", "#f9e2af", "#eba0ac", "#b4befe",
  "#74c7ec", "#f38ba8",
];
const hashColor = (s) => {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
  return BAR_COLORS[h % BAR_COLORS.length];
};

const toMin = (hhmm) => {
  const [h, m] = hhmm.split(":").map(Number);
  return h * 60 + m;
};
const parseDur = (s) => {
  if (!s) return 0;
  let t = 0;
  const d = s.match(/(\d+)d/), h = s.match(/(\d+)h/), m = s.match(/(\d+)m/);
  if (d) t += +d[1] * 1440;
  if (h) t += +h[1] * 60;
  if (m) t += +m[1];
  return t;
};
const pad = (n) => String(n).padStart(2, "0");
const dayName = (iso) =>
  new Date(iso + "T00:00:00").toLocaleDateString("en-US", { weekday: "long" });
const fmtDate = (iso) =>
  new Date(iso + "T00:00:00").toLocaleDateString("en-US", {
    month: "short", day: "numeric",
  });

const shortDay = (iso) =>
  new Date(iso + "T00:00:00").toLocaleDateString("en-US", { weekday: "short" });
const addDays = (iso, n) => {
  const dt = new Date(iso + "T00:00:00");
  dt.setDate(dt.getDate() + n);
  return `${dt.getFullYear()}-${pad(dt.getMonth() + 1)}-${pad(dt.getDate())}`;
};
const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));

// ---- group by day, compute per-day span (the axis mapping) ----
const byDate = new Map();
for (const e of events) {
  if (!byDate.has(e.date)) byDate.set(e.date, []);
  byDate.get(e.date).push(e);
}

const groups = [];
for (const [date, items] of byDate) {
  const evs = items.map((e) => {
    const allDay = e.start === "all-day";
    const startMin = allDay ? 0 : toMin(e.start);
    let durMin = allDay ? 1440 : parseDur(e.dur);
    if (!durMin) durMin = e.end ? ((toMin(e.end) - startMin + 1440) % 1440) || 60 : 60;
    const endAbs = startMin + durMin;
    const renderEnd = Math.min(endAbs, 1440); // clamped within the day, for span/peak only
    return { ...e, allDay, startMin, durMin, endAbs, renderEnd };
  });

  const dayMin = Math.min(...evs.map((e) => e.startMin));
  const dayMax = Math.max(...evs.map((e) => e.renderEnd));
  const spanStart = Math.floor(dayMin / 60) * 60;
  let spanEnd = Math.ceil(dayMax / 60) * 60;
  if (spanEnd <= spanStart) spanEnd = spanStart + 60;
  const width = (spanEnd - spanStart) * PX_PER_MIN;

  // peak concurrency within the day (sweep line) — for the day label
  const pts = [];
  for (const e of evs) { pts.push([e.startMin, 1], [e.renderEnd, -1]); }
  pts.sort((a, b) => a[0] - b[0] || a[1] - b[1]);
  let cur = 0, peak = 0;
  for (const [, d] of pts) { cur += d; if (cur > peak) peak = cur; }

  // hour ticks (relative to this day's span)
  const ticks = [];
  for (let m = spanStart; m <= spanEnd; m += 60) {
    ticks.push({ x: (m - spanStart) * PX_PER_MIN, label: `${pad((m / 60) % 24)}:00` });
  }

  groups.push({
    date, day: dayName(date), pretty: fmtDate(date),
    count: evs.length, spanStart, spanEnd, width, peak, ticks, events: evs,
  });
}
groups.sort((a, b) => a.date.localeCompare(b.date));

// ---- lay days end-to-end on ONE continuous axis ----
let cursor = SIDE_PAD;
for (const g of groups) {
  g.offset = cursor;
  cursor += g.width + DAY_GAP;
}
const totalWidth = cursor - DAY_GAP + SIDE_PAD;
const firstDate = groups[0].date;
const lastG = groups[groups.length - 1];
const lastDate = lastG.date;
const dayIndex = new Map(groups.map((g, i) => [g.date, i]));
const daysFromFirst = new Map(
  groups.map((g) => [
    g.date,
    Math.round((new Date(g.date + "T00:00:00") - new Date(firstDate + "T00:00:00")) / 86400000),
  ])
);

// map any (date, minute-of-day) to a global X on the collapsed axis
const xOf = (dateStr, minute) => {
  const idx = dayIndex.get(dateStr);
  if (idx != null) {
    const g = groups[idx];
    return g.offset + (clamp(minute, g.spanStart, g.spanEnd) - g.spanStart) * PX_PER_MIN;
  }
  if (dateStr < firstDate) return groups[0].offset;
  if (dateStr > lastDate) return lastG.offset + lastG.width;
  // date sits in a collapsed gap → snap to the preceding present day's right edge
  let prev = groups[0];
  for (const g of groups) if (g.date < dateStr) prev = g;
  return prev.offset + prev.width;
};

// ---- event categories: keyword-derived, for the bulk select-by-type checkboxes ----
const CAT_RULES = [
  { key: "dance",    label: "🪩 Dance",            kw: ["danc","liminal","contact improv","foxtrot","rumba","swing","ceili","ballroom","parade","emo night"] },
  { key: "music",    label: "🎵 Music",            kw: ["sing","karaoke","jam","shant","in c by","song","sound check","fake artist","music","instrument","auld lang"] },
  { key: "food",     label: "🍽 Food & Drink",     kw: ["dinner","breakfast","lunch","ramen","cocktail","waffle","eating place","diet coke","drinks","meat in your mouth","electrolytes"] },
  { key: "games",    label: "🎲 Games & Sports",   kw: ["clocktower","mtg","commander","board game","dodgeball","basketball","leg wrestling","sparring","conveyor belt","improv games","trials","metal detector","social deduction","small fishes","dodge","race","fitness challenge"] },
  { key: "wellness", label: "🧘 Wellness & Spirit", kw: ["meditat","jhana","prostration","sun salutation","aerial","yoga","primal scream","breath","noting","circus","ceremon","kava","magick","magic","tarot","shaman","open circle","solstice","spoon"] },
  { key: "art",      label: "🎨 Art & Craft",      kw: ["crochet","color","bracelet","henna","perfume","typewriter","sketch","weave","braiding","craft","slime","3d","phantogram","art of the future","poem","poetry","build"] },
  { key: "talks",    label: "🗣 Talks & Workshops", kw: ["workshop","introduction","intro to","history","lecture","to be done","agency","cohomology","survey","podcast","recording","visual novel","negative feedback","glosso","twirl"] },
  { key: "party",    label: "🎉 Parties & Nightlife", kw: ["party","pool","vibedip","naked","ghost night","hangout","newcomer","cigs","pre-vibecamp"] },
  { key: "film",     label: "🎬 Film & Stars",     kw: ["megalopolis","cartoon","meteor","stargaz","movie","watch party","film"] },
  { key: "kids",     label: "🧒 Kids & Family",    kw: ["kiddie","kids","famil","petting"] },
];
const catKeysOf = (e) => {
  const t = `${e.summary || ""} ${e.desc || ""}`.toLowerCase();
  return CAT_RULES.filter((c) => c.kw.some((k) => t.includes(k))).map((c) => c.key);
};

// ---- build global bars with real (possibly multi-day) spans ----
const allEvents = [];
for (const g of groups) {
  for (const e of g.events) {
    const offDays = Math.floor(e.endAbs / 1440);
    const endMin = e.endAbs - offDays * 1440;
    const endDate = offDays > 0 ? addDays(g.date, offDays) : g.date;
    const leftX = xOf(g.date, e.startMin);
    const rightX = xOf(endDate, endMin);
    const barW = Math.max(rightX - leftX, MIN_BAR);
    const crossesDay = endDate !== g.date;
    const beyondDays =
      endDate > lastDate
        ? Math.round((new Date(endDate + "T00:00:00") - new Date(lastDate + "T00:00:00")) / 86400000)
        : 0;
    const endLabel = beyondDays > 0
      ? `+${beyondDays}d`
      : `${shortDay(endDate)} ${pad(Math.floor(endMin / 60))}:${pad(endMin % 60)}`;
    const baseTime = e.allDay ? "all-day" : `${e.start}${e.end ? "–" + e.end : ""}`;
    const absStart = daysFromFirst.get(g.date) * 1440 + e.startMin;
    allEvents.push({
      ...e,
      leftX, barW, crossesDay, beyondDays, endLabel,
      date: g.date,
      absStart, absEnd: absStart + e.durMin,
      color: hashColor(e.org || e.summary || "x"),
      timeLabel: crossesDay ? `${e.start} → ${endLabel}` : baseTime,
      dayFull: `${g.day}, ${g.pretty}`,
      cats: catKeysOf(e),
    });
  }
}

// ---- venues on the Y axis: group by location, sub-lane pack within each ----
const UNLISTED = "Unlisted";
const venueOf = (e) => (e.location && e.location.trim()) ? e.location.trim() : UNLISTED;
const venueCount = new Map();
for (const e of allEvents) { const v = venueOf(e); venueCount.set(v, (venueCount.get(v) || 0) + 1); }
// busiest venues on top, ties alphabetical; Unlisted always last
const venueNames = [...venueCount.keys()]
  .filter((v) => v !== UNLISTED)
  .sort((a, b) => venueCount.get(b) - venueCount.get(a) || a.localeCompare(b));
if (venueCount.has(UNLISTED)) venueNames.push(UNLISTED);

const venueRows = [];
let yCursor = 0;
for (const name of venueNames) {
  const evs = allEvents
    .filter((e) => venueOf(e) === name)
    .sort((a, b) => a.leftX - b.leftX || (a.leftX + a.barW) - (b.leftX + b.barW));
  const laneEnds = [];
  for (const e of evs) {
    let lane = laneEnds.findIndex((end) => end <= e.leftX + 0.5);
    if (lane === -1) { lane = laneEnds.length; laneEnds.push(0); }
    laneEnds[lane] = e.leftX + e.barW;
    e.subLane = lane;
  }
  const lanes = Math.max(1, laneEnds.length);
  const height = lanes * (LANE_H + LANE_GAP) - LANE_GAP;
  for (const e of evs) e.top = yCursor + e.subLane * (LANE_H + LANE_GAP);
  venueRows.push({ name, count: venueCount.get(name), yOffset: yCursor, height, lanes, alt: venueRows.length % 2 === 1 });
  yCursor += height + VENUE_GAP;
}
const lanesHeight = Math.max(0, yCursor - VENUE_GAP);

const bands = groups.map((g, i) => ({
  left: g.offset, width: g.width,
  day: g.day, pretty: g.pretty, count: g.count, peak: g.peak, first: i === 0,
}));
const hourTicks = groups.flatMap((g) =>
  g.ticks.map((t) => ({ x: g.offset + t.x, label: t.label }))
);
const bars = allEvents.map((e) => ({ ...e, gleft: e.leftX }));

const totalEvents = events.length;
const totalDays = groups.length;
const totalVenues = venueNames.length;

const catCounts = {};
for (const e of allEvents) for (const k of e.cats) catCounts[k] = (catCounts[k] || 0) + 1;
const CATS = CAT_RULES.map((c) => ({ key: c.key, label: c.label, count: catCounts[c.key] || 0 })).filter((c) => c.count > 0);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Vibecamp 2026 · Continuous Timeline</title>
    <meta name="description" content="The Vibecamp 2026 schedule as one continuous lateral timeline." />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="vibecamp_logo.png" />
    <link rel="apple-touch-icon" href="vibecamp_logo.png" />
    <meta property="og:title" content="Vibecamp 2026 Timeline" />
    <meta property="og:description" content="The whole Vibecamp 2026 schedule on one continuous timeline." />
    <meta property="og:image" content="https://vibecamp.mahan.io/vibecamp_logo.png" />
    <meta name="twitter:card" content="summary" />
    <script is:inline>
      // set theme before first paint to avoid a flash of the wrong palette
      (function () {
        var t = "system";
        try { t = localStorage.getItem("vc-theme") || "system"; } catch (e) {}
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
  </head>
  <body>
    <div class="aurora"></div>
    <header class="hero">
      <p class="kicker">✦ Vibe Camp</p>
      <h1>2026 Event Timeline</h1>
      <p class="tagline">
        This year's schedule, paired with a schedule maker. Send bugs to
        <a href="https://twitter.com/timebard" target="_blank" rel="noopener">@timebard</a>
        on twitter!
      </p>
      <div class="controls">
        <span class="hint">↔ drag to scroll · click events to build a PDF schedule</span>
      </div>
      <p class="search-note">Searching spotlights matching events — they stay lit while the rest dim, and the timeline jumps to the first match.</p>
    </header>

    <main>
      <div class="toolbars">
        <div class="tb-group tb-utility">
          <span class="tb-head">Utility</span>
          <label class="zoom">
            <span class="zoom-label">Zoom</span>
            <span class="zoom-icon" aria-hidden="true">⊖</span>
            <input id="zoom" type="range" min="0.1" max="2" step="0.05" value="1" aria-label="Zoom timeline" />
            <span class="zoom-icon" aria-hidden="true">⊕</span>
          </label>
          <div class="search-wrap">
            <span class="search-icon">⌕</span>
            <input id="search" type="search" placeholder="Filter events, hosts, or places…" autocomplete="off" />
            <button id="search-clear" class="search-clear" type="button" aria-label="Clear search" hidden>✕</button>
          </div>
          <span id="count" class="count">{totalEvents} events</span>
          <button id="view-toggle" class="view-toggle" type="button">📍 Location view</button>
          <button id="map-btn" class="view-toggle" type="button">🗺 Map</button>
          <button id="clock-toggle" class="view-toggle" type="button">🕐 Clock: 24h</button>
          <button id="theme-toggle" class="view-toggle" type="button">🌗 Theme: System</button>
          <button id="collapse-all" class="collapse-all" type="button">⊟ Collapse all</button>
        </div>
        <div class="tb-group tb-select">
          <span class="tb-head">Select events</span>
          <button id="randomize-btn" class="view-toggle" type="button"><span class="die">🎲</span> Randomize</button>
          <button id="core-btn" class="view-toggle" type="button">✦ Core events</button>
          {CATS.map((c) => (
            <label class="cat-chip">
              <input type="checkbox" class="cat-cb" data-cat={c.key} />
              <span class="cat-chip-label">{c.label}</span>
              <span class="cat-n">{c.count}</span>
            </label>
          ))}
        </div>
      </div>
      <p class="scroll-hint">More events that way! <span class="scroll-arrow">→</span></p>
      <div class="timeline-wrap">
        <!-- static venue axis (does not scroll horizontally) -->
        <div class="vaxis">
          <div class="vaxis-head" id="axis-head">Venue</div>
          <div class="vaxis-rows" id="venue-rows" style={`height:${lanesHeight}px`}>
            {venueRows.map((v) => (
              <button type="button" class={`vlabel ${v.alt ? "alt" : ""}`} data-venue={v.name} data-h={v.height} style={`top:${v.yOffset}px;height:${v.height}px`}>
                <span class="vchevron" aria-hidden="true">▾</span>
                <span class="vlabel-name">{v.name}</span>
                <span class="vlabel-count">{v.count}</span>
              </button>
            ))}
          </div>
          <div class="vaxis-rows" id="track-rows" hidden></div>
        </div>

        <div class="scroll" id="scroll">
          <div class="chart" id="chart" data-tw={totalWidth} style={`width:${totalWidth}px`}>
            <div class="daylabels" id="daylabels" style={`width:${totalWidth}px`}>
              {bands.map((b) => (
                <div class="daylabel" data-bx={b.left} data-bw={b.width} style={`left:${b.left}px;width:${b.width}px`}>
                  <span class="dl-day">{b.day}</span>
                  <span class="dl-date">{b.pretty}</span>
                  <span class="dl-meta">{b.count} events · {b.peak} at peak</span>
                </div>
              ))}
            </div>

            <div class="ruler">
              {hourTicks.map((t) => (
                <span class="tick" data-bx={t.x} data-clock={t.label} style={`left:${t.x}px`}>{t.label}</span>
              ))}
            </div>

            <div class="lanes" style={`height:${lanesHeight}px`}>
              {venueRows.map((v) => (
                <span class={`vband ${v.alt ? "alt" : ""}`} data-venue={v.name} data-h={v.height} data-bx={0} data-bw={totalWidth} style={`top:${v.yOffset}px;height:${v.height}px;left:0;width:${totalWidth}px`} />
              ))}
              {bands.map((b) => (!b.first &&
                <span class="divider" data-bx={b.left - DAY_GAP / 2} style={`left:${b.left - DAY_GAP / 2}px`} />
              ))}
              {hourTicks.map((t) => (
                <span class="grid" data-bx={t.x} style={`left:${t.x}px`} />
              ))}
              {bars.map((e, i) => (
                <button
                  class={`bar ${e.crossesDay ? "multi" : ""} ${e.summary === "Vibecamp Trials" ? "trials" : ""} ${(e.org === "Leah (Prime)" || e.summary === "Welcome to the Vibe Parade") ? "sheen" : ""}`}
                  id={`ev${i}`}
                  data-bx={e.gleft} data-bw={e.barW}
                  style={`left:${e.gleft}px;top:${e.top}px;width:${e.barW}px;--c:${e.color}`}
                  data-search={`${e.summary} ${e.org} ${e.location} ${e.desc}`.toLowerCase()}
                  data-title={e.summary || "Untitled event"}
                  data-time={`${e.timeLabel}${e.dur ? " · " + e.dur : ""}`}
                  data-day={e.dayFull}
                  data-org={e.org}
                  data-loc={e.location}
                  data-desc={e.desc}
                  data-start={e.absStart}
                  data-end={e.absEnd}
                  data-date={e.date}
                  data-shm={e.start}
                  data-clock={e.timeLabel}
                  data-venue={(e.location && e.location.trim()) ? e.location.trim() : "Unlisted"}
                  data-sublane={e.subLane}
                  data-cats={e.cats.join(" ")}
                >
                  <span class="bar-check" aria-hidden="true">✓</span>
                  <span class="bar-time">{e.timeLabel}</span>
                  <span class="bar-title">{e.summary || "Untitled event"}</span>
                  {e.crossesDay && <span class="bar-cap" aria-hidden="true">›</span>}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
      <p id="empty" class="empty" hidden>No events match your filter.</p>
    </main>

    <footer>
      <p>Generated from the Vibecamp event calendar · times in Eastern (ET) · empty stretches between days are collapsed · {totalEvents} events in 2026</p>
    </footer>

    <aside id="panel" class="panel" hidden>
      <button id="panel-close" class="panel-close" aria-label="Close">✕</button>
      <h3 id="p-title"></h3>
      <div class="p-meta">
        <span id="p-time" class="p-chip p-time"></span>
        <span id="p-day" class="p-chip"></span>
        <span id="p-org" class="p-chip p-org"></span>
        <span id="p-loc" class="p-chip p-loc"></span>
      </div>
      <p id="p-desc" class="p-desc"></p>
      <button id="p-toggle" class="p-toggle">+ Add to my schedule</button>
    </aside>

    <!-- selection tray -->
    <div id="tray" class="tray">
      <button id="tray-toggle" class="tray-min" type="button" aria-label="Minimize schedule bar">▾</button>
      <span class="tray-count"><b id="tray-n">0</b> selected</span>
      <span id="tray-hint" class="tray-hint">— click events to build your schedule</span>
      <span id="tray-warn" class="tray-warn" hidden></span>
      <span class="tray-spacer"></span>
      <button id="howto-btn" class="tray-btn ghost">❔ How to use?</button>
      <button id="tray-review" class="tray-btn ghost" hidden>Review overlaps</button>
      <button id="tray-clear" class="tray-btn ghost" disabled>Clear</button>
      <button id="tray-export" class="tray-btn primary" disabled>⤓ Export</button>
    </div>

    <!-- overlap review modal -->
    <div id="review" class="review" hidden>
      <div class="review-card">
        <button id="review-close" class="review-x" aria-label="Close">✕</button>
        <h3>Review overlapping events</h3>
        <p id="review-sub" class="review-sub"></p>
        <div id="review-list" class="review-list"></div>
        <div class="review-actions">
          <button id="review-allok" class="rv-btn ghost">Mark all OK</button>
          <span class="tray-spacer"></span>
          <button id="review-cancel" class="rv-btn ghost">Back</button>
          <button id="review-pdf" class="rv-btn primary">⎙ Create PDF</button>
        </div>
      </div>
    </div>

    <!-- export modal -->
    <div id="export" class="review" hidden>
      <div class="review-card">
        <button id="export-close" class="review-x" aria-label="Close">✕</button>
        <h3>Export your schedule</h3>
        <p class="review-sub">Take your <b id="export-n">0</b>-event schedule with you.</p>
        <div class="export-opts">
          <button id="export-ics" class="export-opt" type="button">
            <span class="export-emoji">📅</span>
            <span class="export-txt"><b>Add to calendar</b><small>Download an <code>.ics</code> file — imports into Apple&nbsp;Calendar, Google&nbsp;Calendar or Outlook. Times in Eastern (ET).</small></span>
          </button>
          <button id="export-pdf" class="export-opt" type="button">
            <span class="export-emoji">⎙</span>
            <span class="export-txt"><b>PDF schedule</b><small>A printable one-page schedule. Overlapping picks get flagged for review first.</small></span>
          </button>
        </div>
        <label class="export-mapchk" title="Include the camp map at the top of the PDF">
          <input type="checkbox" id="map-pdf" checked /> 🗺 Include the camp map in the PDF
        </label>
      </div>
    </div>

    <!-- how-to guide modal -->
    <div id="howto" class="review" hidden>
      <div class="review-card">
        <button id="howto-close" class="review-x" aria-label="Close">✕</button>
        <h3>How to use this schedule</h3>
        <ul class="howto-body">
          <li><b>Move around:</b> drag (or swipe on mobile) to scroll along the timeline. <b>Zoom</b> scales the time axis in and out, centered on whatever's in the middle of your view.</li>
          <li><b>Two toolbars:</b> <b>Utility</b> holds the view controls (zoom, search, view, clock, map); <b>Select events</b> holds the picking tools. On mobile they sit above and below the timeline.</li>
          <li><b>Two views:</b> <b>Location view</b> groups events by venue; <b>Row view</b> packs them compactly into rows, with long events shown as a striped layer underneath the shorter ones.</li>
          <li><b>Search</b> to spotlight matching events — they stay lit while the rest dim, and the timeline jumps to the first match.</li>
          <li><b>Build a schedule:</b> click an event to look at it and add it, or pick in bulk (below). Then <b>Export</b> to add it to your calendar (.ics for Apple / Google / Outlook) or save a printable PDF — overlapping picks get flagged for review before the PDF.</li>
        </ul>
        <div class="howto-divider"></div>
        <p class="howto-subhead">Picking events fast</p>
        <ul class="howto-body">
          <li><b>✦ Core events</b> adds the meals plus the opening &amp; closing ceremonies in one tap.</li>
          <li><b>Select by type</b> checkboxes pick or clear a whole category at once (dance, music, food, games…). A dash means only some of that type are currently selected.</li>
          <li><b>🎲 Randomize</b> builds a random conflict-free schedule you can tweak from.</li>
        </ul>
        <div class="howto-divider"></div>
        <p class="howto-subhead">Extra features</p>
        <ul class="howto-body">
          <li><b>🗺 Map</b> opens the camp map; tick <b>Include the camp map in the PDF</b> in the Export dialog to print it at the top of your schedule.</li>
          <li><b>Clock toggle</b> switches every time between 24-hour and am/pm (PDF included).</li>
          <li><b>Row labels</b> show how many events sit in each row.</li>
        </ul>
        <div class="review-actions">
          <span class="tray-spacer"></span>
          <button id="howto-ok" class="rv-btn primary">Got it</button>
        </div>
      </div>
    </div>

    <!-- camp map modal -->
    <div id="mapmodal" class="review" hidden>
      <div class="review-card mapcard">
        <button id="mapmodal-close" class="review-x" aria-label="Close">✕</button>
        <h3>Camp map</h3>
        <img class="mapfull" src="vibecamp-map.jpg" alt="Vibecamp 5 camp map — Camp Ramblewood, MD" />
      </div>
    </div>

    <!-- printable schedule (hidden on screen, shown only when printing) -->
    <div id="print-schedule" class="print-schedule" aria-hidden="true">
      <header class="ps-head">
        <img class="ps-logo" src="vibecamp_logo.png" alt="" />
        <div class="ps-headtext">
          <p class="ps-kicker">✦ Vibe Camp 2026</p>
          <h1>My Schedule</h1>
          <p id="ps-sub" class="ps-sub"></p>
        </div>
      </header>
      <div id="ps-warn" class="ps-warn" hidden></div>
      <div id="ps-map" class="ps-map" hidden>
        <h2 class="ps-map-h">Camp map</h2>
        <img src="vibecamp-map.jpg" alt="Vibecamp 5 camp map — Camp Ramblewood, MD" />
      </div>
      <div id="ps-body"></div>
      <footer class="ps-foot">Built from the Vibecamp event calendar · times shown in Eastern (ET) · vibecamp.mahan.io</footer>
    </div>

    <script is:inline>
      const search = document.getElementById("search");
      const searchClear = document.getElementById("search-clear");
      const count = document.getElementById("count");
      const empty = document.getElementById("empty");
      const bars = Array.from(document.querySelectorAll(".bar"));

      // ---- clock format: 24h by default; toggle reformats every HH:MM for display ----
      // Times are stored 24h in the data attributes; fmtClock is applied wherever a
      // time is shown (bars, ruler, panel, overlap review, PDF) so the toggle is global.
      let use12hr = false;
      try { use12hr = localStorage.getItem("vc-clock") === "12"; } catch (e) {}
      const fmtClock = (str) => {
        if (!use12hr || !str) return str;
        return str.replace(/(\d{1,2}):(\d{2})/g, (_, h, mi) => {
          h = +h; const ap = h < 12 ? "am" : "pm"; const h12 = (h % 12) || 12;
          return h12 + ":" + mi + " " + ap;
        });
      };
      function applyClockFormat() {
        for (const b of bars) {
          const t = b.querySelector(".bar-time");
          if (t) t.textContent = fmtClock(b.dataset.clock);
        }
        for (const tk of document.querySelectorAll(".ruler .tick")) tk.textContent = fmtClock(tk.dataset.clock);
      }

      function applyFilter() {
        const q = search.value.trim().toLowerCase();
        let visible = 0;
        for (const b of bars) {
          const match = !q || b.dataset.search.includes(q);
          b.classList.toggle("dim", !match);
          if (match) visible++;
        }
        count.textContent = visible + (visible === 1 ? " event" : " events");
        empty.hidden = visible !== 0;
        searchClear.hidden = q === "";
        // venue view: collapse venues with no matches (tracks view: layout is fixed)
        if (viewMode === "venues") layoutVenues(q !== "");
        if (q) {
          const firstMatch = bars.find((b) => !b.classList.contains("dim") && b.offsetParent !== null);
          if (firstMatch) {
            const sc = document.getElementById("scroll");
            const delta = firstMatch.getBoundingClientRect().left - sc.getBoundingClientRect().left;
            sc.scrollTo({ left: Math.max(0, sc.scrollLeft + delta - 48), behavior: "smooth" });
          }
        }
      }
      search.addEventListener("input", applyFilter);
      searchClear.addEventListener("click", () => { search.value = ""; applyFilter(); search.focus(); });

      // ---- zoom: rescale the time (X) axis; venue rows (Y) are unaffected ----
      const zoom = document.getElementById("zoom");
      const chart = document.getElementById("chart");
      const daylabels = document.getElementById("daylabels");
      const baseWidth = +chart.dataset.tw;
      const xEls = Array.from(document.querySelectorAll("[data-bx]"));
      let curZoom = 1;   // tracks the applied scale so we can re-anchor on change
      function setZoom(z) {
        for (const el of xEls) {
          el.style.left = (+el.dataset.bx * z) + "px";
          if (el.dataset.bw != null) el.style.width = (+el.dataset.bw * z) + "px";
        }
        const w = (baseWidth * z) + "px";
        chart.style.width = w; daylabels.style.width = w;
        curZoom = z;
      }
      // zoom around the viewport midline: keep whatever's centered now centered after
      function zoomTo(z) {
        const sc = document.getElementById("scroll");
        const centerBase = (sc.scrollLeft + sc.clientWidth / 2) / curZoom;   // content point at center
        setZoom(z);
        sc.scrollLeft = centerBase * z - sc.clientWidth / 2;
      }
      zoom.addEventListener("input", () => {
        zoomTo(+zoom.value);
        try { localStorage.setItem("vc-zoom", zoom.value); } catch (e) {}
      });
      // restore saved zoom; with no saved preference, default mobile to a far-out
      // overview (near max zoom-out) since the timeline is very wide on a phone.
      let savedZoom = null;
      try { savedZoom = localStorage.getItem("vc-zoom"); } catch (e) {}
      const isMobile = window.matchMedia("(max-width: 560px)").matches;
      zoom.value = savedZoom != null ? savedZoom : (isMobile ? "0.2" : "1");
      setZoom(+zoom.value);

      // ---- layout engine: "venues" (default) or compact "tracks" ----
      const LH = 46, LG = 8, ROW = LH + LG;   // lane height / gap
      const VGAP = 12;                          // gap between venues
      const COLLAPSED_H = 30;
      const BG_MIN = 180;   // minutes (3h): events this long become the background layer in compact view
      const lanesEl = document.querySelector(".lanes");
      const venueRowsEl = document.getElementById("venue-rows");
      const trackRowsEl = document.getElementById("track-rows");
      const axisHead = document.getElementById("axis-head");
      const collapseAllBtn = document.getElementById("collapse-all");
      const viewToggleBtn = document.getElementById("view-toggle");
      const manualCollapsed = new Set();
      let viewMode = "venues";

      // venue model
      const vlabels = Array.from(document.querySelectorAll(".vlabel"));
      const vbands = Array.from(document.querySelectorAll(".vband"));
      const venues = vlabels.map((label, i) => ({
        name: label.dataset.venue, label, band: vbands[i], h: +label.dataset.h, bars: [],
      }));
      const vByName = new Map(venues.map((v) => [v.name, v]));
      for (const b of bars) { const v = vByName.get(b.dataset.venue); if (v) v.bars.push(b); }

      // compact "tracks" model: long events → background layer, the rest packed into tracks
      const left = (b) => +b.dataset.bx;
      const right = (b) => +b.dataset.bx + (+b.dataset.bw);
      const bgSet = new Set();
      const fg = [];
      for (const b of bars) {
        if ((+b.dataset.end - +b.dataset.start) >= BG_MIN) bgSet.add(b);
        else fg.push(b);
      }
      fg.sort((a, b) => left(a) - left(b) || right(a) - right(b));
      const trackEnds = [], trackCounts = [], trackOf = new Map();
      for (const b of fg) {
        let t = trackEnds.findIndex((end) => end <= left(b) + 0.5);
        if (t === -1) { t = trackEnds.length; trackEnds.push(0); trackCounts.push(0); }
        trackEnds[t] = right(b); trackOf.set(b, t); trackCounts[t]++;
      }
      const K = Math.max(1, trackEnds.length);
      const trackAreaH = K * ROW - LG;
      // long (bg) events get their OWN greedy lane-packing so each is bound to a
      // single row (not the full track-area height). Rendered slightly taller than
      // short events so their edges peek out from under the short events on top.
      const BG_PEEK = 8;
      const bgArr = bars.filter((b) => bgSet.has(b)).sort((a, b) => left(a) - left(b) || right(a) - right(b));
      const bgEnds = [], bgLaneCounts = [], bgLaneOf = new Map();
      for (const b of bgArr) {
        let l = bgEnds.findIndex((end) => end <= left(b) + 0.5);
        if (l === -1) { l = bgEnds.length; bgEnds.push(0); bgLaneCounts.push(0); }
        bgEnds[l] = right(b); bgLaneOf.set(b, l); bgLaneCounts[l]++;
      }
      const bgLanes = bgEnds.length;
      // total rows = the short-event tracks PLUS any extra rows the long-event
      // underneath layer needs. Label every row so the labels don't stop short.
      const TROWS = Math.max(K, bgLanes);
      const compactAreaH = TROWS * ROW - LG;
      const tbands = [];
      for (let i = 0; i < TROWS; i++) {
        const lbl = document.createElement("div");
        lbl.className = "tlabel" + (i % 2 ? " alt" : "");
        lbl.style.top = (i * ROW) + "px"; lbl.style.height = LH + "px";
        const count = (trackCounts[i] || 0) + (bgLaneCounts[i] || 0);
        const c = document.createElement("span"); c.className = "vlabel-count"; c.textContent = count;
        const n = document.createElement("span"); n.className = "vlabel-name"; n.textContent = "events";
        lbl.append(c, n); trackRowsEl.appendChild(lbl);   // count first, then "events"
        const band = document.createElement("span");
        band.className = "tband" + (i % 2 ? " alt" : "");
        band.style.top = (i * ROW) + "px"; band.style.height = LH + "px"; band.style.display = "none";
        lanesEl.appendChild(band); tbands.push(band);
      }

      // per-venue layout: FG (short) events sub-lane-packed, long events as a background layer
      const fgSubLane = new Map();
      for (const v of venues) {
        v.fgBars = v.bars.filter((b) => !bgSet.has(b)).sort((a, b) => left(a) - left(b) || right(a) - right(b));
        v.bgBars = v.bars.filter((b) => bgSet.has(b));
        const ends = [];
        for (const b of v.fgBars) {
          let l = ends.findIndex((e) => e <= left(b) + 0.5);
          if (l === -1) { l = ends.length; ends.push(0); }
          ends[l] = right(b); fgSubLane.set(b, l);
        }
        v.fgLanes = Math.max(1, ends.length);
        v.h = v.fgLanes * ROW - LG;
      }

      function layoutVenues(searchActive) {
        let y = 0;
        for (const v of venues) {
          const matches = searchActive ? v.bars.filter((b) => !b.classList.contains("dim")).length : v.bars.length;
          if (searchActive && matches === 0) {
            v.label.style.display = "none"; v.band.style.display = "none";
            for (const b of v.bars) b.style.display = "none";
            continue;
          }
          v.label.style.display = ""; v.band.style.display = "";
          const collapsed = manualCollapsed.has(v.name);
          const h = collapsed ? COLLAPSED_H : v.h;
          v.label.style.top = y + "px"; v.label.style.height = h + "px";
          v.band.style.top = y + "px"; v.band.style.height = h + "px";
          v.label.classList.toggle("collapsed", collapsed);
          v.label.setAttribute("aria-expanded", String(!collapsed));
          for (const b of v.fgBars) {
            b.classList.remove("bgbar"); b.style.height = "";
            if (collapsed) b.style.display = "none";
            else { b.style.display = ""; b.style.top = (y + fgSubLane.get(b) * ROW) + "px"; }
          }
          for (const b of v.bgBars) {
            if (collapsed) { b.classList.remove("bgbar"); b.style.height = ""; b.style.display = "none"; }
            else { b.classList.add("bgbar"); b.style.display = ""; b.style.top = y + "px"; b.style.height = h + "px"; }
          }
          y += h + VGAP;
        }
        const total = Math.max(0, y - VGAP);
        lanesEl.style.height = total + "px";
        venueRowsEl.style.height = total + "px";
      }

      function layoutTracks() {
        for (const b of bars) {
          b.style.display = "";
          if (bgSet.has(b)) {
            // underneath layer: one row per long event, slightly taller than a
            // short event so its top/bottom edges peek out from under the events on top.
            // The top lane must not peek UP — there's only the ruler above it, and
            // an upward peek covers the hour-time labels.
            b.classList.add("bgbar");
            const lane = bgLaneOf.get(b);
            const peekUp = lane > 0 ? BG_PEEK : 0;
            b.style.top = (lane * ROW - peekUp) + "px";
            b.style.height = (LH + peekUp + BG_PEEK) + "px";
          } else {
            b.classList.remove("bgbar"); b.style.height = "";
            b.style.top = (trackOf.get(b) * ROW) + "px";
          }
        }
        lanesEl.style.height = compactAreaH + "px";
        trackRowsEl.style.height = compactAreaH + "px";
      }

      function setView(mode) {
        viewMode = mode;
        try { localStorage.setItem("vc-view", mode); } catch (e) {}
        const tracks = mode === "tracks";
        venueRowsEl.hidden = tracks;
        trackRowsEl.hidden = !tracks;
        for (const b of vbands) b.style.display = tracks ? "none" : "";
        for (const b of tbands) b.style.display = tracks ? "" : "none";
        axisHead.textContent = tracks ? (TROWS + " rows · " + bgSet.size + " bg") : "Location";
        collapseAllBtn.style.display = tracks ? "none" : "";
        viewToggleBtn.textContent = tracks ? "📍 Location view" : "☰ Row view";
        if (tracks) layoutTracks(); else layoutVenues(search.value.trim() !== "");
      }
      viewToggleBtn.addEventListener("click", () => setView(viewMode === "tracks" ? "venues" : "tracks"));

      for (const v of venues) {
        v.label.addEventListener("click", () => {
          if (manualCollapsed.has(v.name)) manualCollapsed.delete(v.name);
          else manualCollapsed.add(v.name);
          layoutVenues(search.value.trim() !== "");
          syncCollapseAll();
        });
      }
      function syncCollapseAll() {
        const allCollapsed = venues.every((v) => manualCollapsed.has(v.name));
        collapseAllBtn.textContent = allCollapsed ? "⊞ Expand all" : "⊟ Collapse all";
      }
      collapseAllBtn.addEventListener("click", () => {
        const allCollapsed = venues.every((v) => manualCollapsed.has(v.name));
        if (allCollapsed) manualCollapsed.clear();
        else for (const v of venues) manualCollapsed.add(v.name);
        layoutVenues(search.value.trim() !== "");
        syncCollapseAll();
      });

      let savedView = "tracks";   // track view is the default
      try { savedView = localStorage.getItem("vc-view") || "tracks"; } catch (e) {}
      setView(savedView);
      syncCollapseAll();

      const el = (tag, cls, text) => {
        const n = document.createElement(tag);
        if (cls) n.className = cls;
        if (text != null) n.textContent = text;
        return n;
      };

      const panel = document.getElementById("panel");
      const pToggle = document.getElementById("p-toggle");
      let currentBar = null;
      const set = (id, v) => {
        const e = document.getElementById(id);
        e.textContent = v || "";
        if (e.classList.contains("p-chip")) e.hidden = !v;
      };
      const refreshToggle = () => {
        if (!currentBar) return;
        const on = currentBar.classList.contains("selected");
        pToggle.textContent = on ? "✓ In schedule — remove" : "+ Add to my schedule";
        pToggle.classList.toggle("on", on);
      };
      const show = (b) => {
        if (currentBar && currentBar !== b) currentBar.classList.remove("viewing");
        currentBar = b;
        b.classList.add("viewing");   // glow the event you're looking at, in its own color
        set("p-title", b.dataset.title);
        set("p-time", fmtClock(b.dataset.time));
        set("p-day", b.dataset.day);
        set("p-org", b.dataset.org ? "♟ " + b.dataset.org : "");
        set("p-loc", b.dataset.loc ? "⌖ " + b.dataset.loc : "");
        set("p-desc", b.dataset.desc);
        refreshToggle();
        panel.hidden = false;
      };
      const closePanel = () => { panel.hidden = true; if (currentBar) currentBar.classList.remove("viewing"); };
      // click opens the info popup (selection happens via the panel button)
      bars.forEach((b) => b.addEventListener("click", () => show(b)));
      document.getElementById("panel-close").addEventListener("click", closePanel);
      pToggle.addEventListener("click", () => { if (currentBar) { toggleSelect(currentBar); closePanel(); } });

      // ---- selection + overlap detection ----
      const tray = document.getElementById("tray");
      const trayN = document.getElementById("tray-n");
      const trayHint = document.getElementById("tray-hint");
      const trayWarn = document.getElementById("tray-warn");
      const trayReview = document.getElementById("tray-review");
      const trayClear = document.getElementById("tray-clear");
      const trayExport = document.getElementById("tray-export");
      let conflictPairs = [];
      const ackedOverlaps = new Set();
      const pairKey = (a, b) => [a.id, b.id].sort().join("|");

      const toggleSelect = (b) => { b.classList.toggle("selected"); recompute(); };

      function recompute() {
        const sel = bars.filter((b) => b.classList.contains("selected"));
        bars.forEach((b) => b.classList.remove("conflict"));
        conflictPairs = [];
        const sorted = [...sel].sort((a, b) => (+a.dataset.start) - (+b.dataset.start));
        for (let i = 0; i < sorted.length; i++) {
          for (let j = i + 1; j < sorted.length; j++) {
            const a = sorted[i], b = sorted[j];
            if (+b.dataset.start < +a.dataset.end) {
              a.classList.add("conflict"); b.classList.add("conflict");
              conflictPairs.push([a, b]);
            } else break; // sorted by start: no later event can overlap a
          }
        }
        const nConflict = bars.filter((b) => b.classList.contains("conflict")).length;
        const has = sel.length > 0;
        trayN.textContent = sel.length;
        trayHint.hidden = has;                 // empty-state prompt only when nothing picked
        trayClear.disabled = !has;             // stay visible, just inert until events are picked
        trayExport.disabled = !has;
        trayReview.hidden = conflictPairs.length === 0;
        if (nConflict > 0) {
          trayWarn.hidden = false;
          trayWarn.textContent = `⚠ ${conflictPairs.length} overlap${conflictPairs.length > 1 ? "s" : ""} (${nConflict} events)`;
        } else {
          trayWarn.hidden = true;
        }
        syncCatChecks();
        updateTrayToggle();
      }

      document.getElementById("tray-clear").addEventListener("click", () => {
        bars.forEach((b) => b.classList.remove("selected", "conflict"));
        ackedOverlaps.clear();
        recompute(); refreshToggle();
      });

      // ---- randomize: build a random conflict-free schedule ----
      document.getElementById("randomize-btn").addEventListener("click", () => {
        const die = document.querySelector("#randomize-btn .die");
        if (die) {
          die.classList.remove("rolling");
          void die.offsetWidth;            // reflow so the animation can re-trigger
          die.classList.add("rolling");
          die.addEventListener("animationend", () => die.classList.remove("rolling"), { once: true });
        }
        bars.forEach((b) => b.classList.remove("selected", "conflict"));
        ackedOverlaps.clear();
        const picked = [];
        for (const b of [...bars].sort(() => Math.random() - 0.5)) {
          const bs = +b.dataset.start, be = +b.dataset.end;
          if (!picked.some((p) => bs < +p.dataset.end && +p.dataset.start < be)) {
            b.classList.add("selected"); picked.push(b);
          }
        }
        recompute(); refreshToggle();
      });

      // ---- core events: add the mealtimes + opening/closing ceremonies to the schedule ----
      const CORE = new Set(["Breakfast", "Lunch", "Dinner", "Opening Ceremonies", "Closing Ceremonies"]);
      document.getElementById("core-btn").addEventListener("click", () => {
        for (const b of bars) if (CORE.has(b.dataset.title)) b.classList.add("selected");
        recompute(); refreshToggle();
      });

      // ---- select-by-type: each checkbox bulk-selects / deselects its category ----
      const catCbs = Array.from(document.querySelectorAll(".cat-cb"));
      const catBars = new Map();
      for (const cb of catCbs) {
        catBars.set(cb.dataset.cat, bars.filter((b) => (b.dataset.cats || "").split(" ").includes(cb.dataset.cat)));
      }
      catCbs.forEach((cb) => cb.addEventListener("change", () => {
        for (const b of (catBars.get(cb.dataset.cat) || [])) b.classList.toggle("selected", cb.checked);
        recompute(); refreshToggle();
      }));
      function syncCatChecks() {
        for (const cb of catCbs) {
          const list = catBars.get(cb.dataset.cat) || [];
          const sel = list.filter((b) => b.classList.contains("selected")).length;
          cb.checked = list.length > 0 && sel === list.length;
          cb.indeterminate = sel > 0 && sel < list.length;
        }
      }
      syncCatChecks();

      // ---- clock-format toggle (re-labels every displayed time + the open panel) ----
      const clockToggle = document.getElementById("clock-toggle");
      const setClockLabel = () => { clockToggle.textContent = use12hr ? "🕐 Clock: 12h" : "🕐 Clock: 24h"; };
      setClockLabel();
      clockToggle.addEventListener("click", () => {
        use12hr = !use12hr;
        try { localStorage.setItem("vc-clock", use12hr ? "12" : "24"); } catch (e) {}
        setClockLabel(); applyClockFormat();
        if (!panel.hidden && currentBar) set("p-time", fmtClock(currentBar.dataset.time));
      });
      if (use12hr) applyClockFormat();   // restore a saved 12h preference on load

      // ---- theme toggle: System → Light → Dark (System follows the OS) ----
      const themeToggle = document.getElementById("theme-toggle");
      const THEME_LABELS = { system: "🌗 Theme: System", light: "☀ Theme: Light", dark: "🌙 Theme: Dark" };
      const THEME_ORDER = ["system", "light", "dark"];
      let theme = document.documentElement.getAttribute("data-theme") || "system";
      const applyTheme = () => {
        document.documentElement.setAttribute("data-theme", theme);
        themeToggle.textContent = THEME_LABELS[theme] || THEME_LABELS.system;
      };
      applyTheme();
      themeToggle.addEventListener("click", () => {
        theme = THEME_ORDER[(THEME_ORDER.indexOf(theme) + 1) % THEME_ORDER.length];
        try { localStorage.setItem("vc-theme", theme); } catch (e) {}
        applyTheme();
      });

      // ---- overlap review modal ----
      const review = document.getElementById("review");
      const reviewList = document.getElementById("review-list");
      const reviewSub = document.getElementById("review-sub");

      const pairsOf = (e) => conflictPairs.filter(([a, b]) => a === e || b === e);

      function renderReview() {
        reviewList.textContent = "";
        // one row per event involved in a conflict, sorted by start time
        const evs = [...new Set(conflictPairs.flat())].sort(
          (a, b) => (+a.dataset.start) - (+b.dataset.start)
        );
        reviewSub.textContent = evs.length
          ? `${evs.length} event${evs.length > 1 ? "s" : ""} with overlaps. Marking an event OK clears every overlap it's part of — resolved ones are simply left out of the PDF.`
          : "No overlaps — you're all clear.";
        for (const e of evs) {
          const mine = pairsOf(e);
          const partners = mine
            .map(([a, b]) => (a === e ? b : a))
            .sort((x, y) => (+x.dataset.start) - (+y.dataset.start));
          const resolved = mine.every(([a, b]) => ackedOverlaps.has(pairKey(a, b)));

          const row = el("div", "rv-row" + (resolved ? " resolved" : ""));
          const info = el("div", "rv-info");
          info.appendChild(el("div", "rv-pair", `${e.dataset.title}  (${fmtClock(e.dataset.clock)})`));
          info.appendChild(el("div", "rv-times",
            "overlaps " + partners.map((p) => `${p.dataset.title} (${p.dataset.clock})`).join(",  ")));
          const btn = el("button", "rv-ok");
          btn.textContent = resolved ? "OK ✓" : "Mark OK";
          btn.classList.toggle("on", resolved);
          btn.addEventListener("click", () => {
            for (const [a, b] of mine) {
              const k = pairKey(a, b);
              if (resolved) ackedOverlaps.delete(k);
              else ackedOverlaps.add(k);
            }
            renderReview(); // re-render so events that share an overlap update too
          });
          row.appendChild(info);
          row.appendChild(btn);
          reviewList.appendChild(row);
        }
      }
      const openReview = () => { renderReview(); review.hidden = false; };
      const closeReview = () => { review.hidden = true; };

      trayReview.addEventListener("click", openReview);
      document.getElementById("review-close").addEventListener("click", closeReview);
      document.getElementById("review-cancel").addEventListener("click", closeReview);
      document.getElementById("review-allok").addEventListener("click", () => {
        for (const [a, b] of conflictPairs) ackedOverlaps.add(pairKey(a, b));
        renderReview();
      });
      document.getElementById("review-pdf").addEventListener("click", () => { closeReview(); doPrint(); });

      // ---- how-to guide modal ----
      const howto = document.getElementById("howto");
      const closeHowto = () => { howto.hidden = true; };
      document.getElementById("howto-btn").addEventListener("click", () => { howto.hidden = false; });
      document.getElementById("howto-close").addEventListener("click", closeHowto);
      document.getElementById("howto-ok").addEventListener("click", closeHowto);
      howto.addEventListener("click", (e) => { if (e.target === howto) closeHowto(); });  // click backdrop to close

      // ---- camp map modal ----
      const mapmodal = document.getElementById("mapmodal");
      const closeMap = () => { mapmodal.hidden = true; };
      document.getElementById("map-btn").addEventListener("click", () => { mapmodal.hidden = false; });
      document.getElementById("mapmodal-close").addEventListener("click", closeMap);
      mapmodal.addEventListener("click", (e) => { if (e.target === mapmodal) closeMap(); });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") { closeReview(); closeHowto(); closeMap(); closeExport(); closePanel(); }
      });

      // ---- build printable schedule & open print dialog (Save as PDF) ----
      function doPrint() {
        const sel = bars
          .filter((b) => b.classList.contains("selected"))
          .sort((a, b) => (+a.dataset.start) - (+b.dataset.start));
        if (!sel.length) return;

        // only unresolved overlaps matter for the PDF; anything marked OK is silent
        const unackedPairs = conflictPairs.filter(([a, b]) => !ackedOverlaps.has(pairKey(a, b)));
        const unackedIds = new Set();
        for (const [a, b] of unackedPairs) { unackedIds.add(a.id); unackedIds.add(b.id); }

        const body = document.getElementById("ps-body");
        body.textContent = "";
        const days = [...new Set(sel.map((b) => b.dataset.day))];
        document.getElementById("ps-sub").textContent =
          `${sel.length} event${sel.length > 1 ? "s" : ""} · ${days.length} day${days.length > 1 ? "s" : ""}`;

        for (const day of days) {
          const dayEvents = sel.filter((x) => x.dataset.day === day);
          const sec = el("section", "ps-day");
          const head = el("h2");
          head.appendChild(el("span", "ps-dayname", day));
          head.appendChild(el("span", "ps-daycount", `${dayEvents.length} event${dayEvents.length > 1 ? "s" : ""}`));
          sec.appendChild(head);
          for (const b of dayEvents) {
            let cls = "ps-item";
            if (unackedIds.has(b.id)) cls += " conflict";
            const item = el("div", cls);
            item.appendChild(el("div", "ps-time", fmtClock(b.dataset.clock)));
            const main = el("div", "ps-main");
            main.appendChild(el("div", "t", b.dataset.title));
            const meta = el("div", "m");
            if (b.dataset.org) meta.appendChild(el("span", "ps-host", "by " + b.dataset.org));
            if (b.dataset.loc) {
              if (b.dataset.org) meta.appendChild(el("span", "ps-dot", "·"));
              meta.appendChild(el("span", "ps-loc", b.dataset.loc));
            }
            if (b.dataset.org || b.dataset.loc) main.appendChild(meta);
            item.appendChild(main);
            sec.appendChild(item);
          }
          body.appendChild(sec);
        }

        const warn = document.getElementById("ps-warn");
        warn.textContent = "";
        warn.hidden = unackedPairs.length === 0;
        if (unackedPairs.length) {
          const box = el("div", "pw-red");
          box.appendChild(el("h4", null, `⚠ ${unackedPairs.length} unresolved time conflict${unackedPairs.length > 1 ? "s" : ""}`));
          for (const [a, b] of unackedPairs)
            box.appendChild(el("div", null, `“${a.dataset.title}” (${a.dataset.clock}) overlaps “${b.dataset.title}” (${b.dataset.clock})`));
          warn.appendChild(box);
        }

        document.getElementById("ps-map").hidden = !document.getElementById("map-pdf").checked;
        window.print();
      }

      // run the existing conflict-gate → review-or-print flow (shared by the PDF paths)
      function startPdf() {
        const hasSel = bars.some((b) => b.classList.contains("selected"));
        if (!hasSel) return;
        const unresolved = conflictPairs.some(([a, b]) => !ackedOverlaps.has(pairKey(a, b)));
        if (unresolved) openReview();  // make the user review conflicts first
        else doPrint();
      }

      // ---- build a calendar .ics from the selected events ----
      const icsEsc = (s) => (s || "").replace(/\\/g, "\\\\").replace(/;/g, "\\;").replace(/,/g, "\\,").replace(/\r?\n/g, "\\n");
      // RFC 5545 line folding: split octets >75 onto continuation lines (leading space)
      function icsFold(line) {
        if (line.length <= 75) return line;
        const out = [line.slice(0, 75)];
        let rest = line.slice(75);
        while (rest.length > 74) { out.push(" " + rest.slice(0, 74)); rest = rest.slice(74); }
        out.push(" " + rest);
        return out.join("\r\n");
      }
      const TZBLOCK = [
        "BEGIN:VTIMEZONE", "TZID:America/New_York",
        "BEGIN:DAYLIGHT", "TZOFFSETFROM:-0500", "TZOFFSETTO:-0400", "TZNAME:EDT",
        "DTSTART:19700308T020000", "RRULE:FREQ=YEARLY;BYMONTH=3;BYDAY=2SU", "END:DAYLIGHT",
        "BEGIN:STANDARD", "TZOFFSETFROM:-0400", "TZOFFSETTO:-0500", "TZNAME:EST",
        "DTSTART:19701101T020000", "RRULE:FREQ=YEARLY;BYMONTH=11;BYDAY=1SU", "END:STANDARD",
        "END:VTIMEZONE",
      ];
      const p2 = (n) => String(n).padStart(2, "0");
      function buildICS(sel) {
        const now = new Date();
        const stamp = `${now.getUTCFullYear()}${p2(now.getUTCMonth() + 1)}${p2(now.getUTCDate())}T${p2(now.getUTCHours())}${p2(now.getUTCMinutes())}${p2(now.getUTCSeconds())}Z`;
        const lines = ["BEGIN:VCALENDAR", "VERSION:2.0", "PRODID:-//vibecamp-scheduler//EN", "CALSCALE:GREGORIAN", "METHOD:PUBLISH", "X-WR-CALNAME:Vibecamp schedule", ...TZBLOCK];
        for (const b of sel) {
          const date = b.dataset.date, shm = b.dataset.shm;
          lines.push("BEGIN:VEVENT", `UID:${b.id}@vibecamp.mahan.io`, `DTSTAMP:${stamp}`);
          if (shm === "all-day" || !/^\d{1,2}:\d{2}$/.test(shm)) {
            const d = date.replace(/-/g, "");
            const next = new Date(date + "T00:00:00"); next.setDate(next.getDate() + 1);
            const nd = `${next.getFullYear()}${p2(next.getMonth() + 1)}${p2(next.getDate())}`;
            lines.push(`DTSTART;VALUE=DATE:${d}`, `DTEND;VALUE=DATE:${nd}`);
          } else {
            const [h, m] = shm.split(":").map(Number);
            const durMin = (+b.dataset.end) - (+b.dataset.start);
            const s = new Date(date + "T00:00:00"); s.setHours(h, m, 0, 0);
            const e = new Date(s.getTime()); e.setMinutes(e.getMinutes() + (durMin > 0 ? durMin : 60));
            const fmt = (x) => `${x.getFullYear()}${p2(x.getMonth() + 1)}${p2(x.getDate())}T${p2(x.getHours())}${p2(x.getMinutes())}00`;
            lines.push(`DTSTART;TZID=America/New_York:${fmt(s)}`, `DTEND;TZID=America/New_York:${fmt(e)}`);
          }
          lines.push(`SUMMARY:${icsEsc(b.dataset.title)}`);
          if (b.dataset.loc) lines.push(`LOCATION:${icsEsc(b.dataset.loc)}`);
          const desc = [b.dataset.org ? "Host: " + b.dataset.org : "", b.dataset.desc || ""].filter(Boolean).join("\n\n");
          if (desc) lines.push(`DESCRIPTION:${icsEsc(desc)}`);
          lines.push("END:VEVENT");
        }
        lines.push("END:VCALENDAR");
        return lines.map(icsFold).join("\r\n");
      }
      function downloadICS() {
        const sel = bars
          .filter((b) => b.classList.contains("selected"))
          .sort((a, b) => (+a.dataset.start) - (+b.dataset.start));
        if (!sel.length) return;
        const blob = new Blob([buildICS(sel)], { type: "text/calendar;charset=utf-8" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url; a.download = "vibecamp-schedule.ics";
        document.body.appendChild(a); a.click(); a.remove();
        setTimeout(() => URL.revokeObjectURL(url), 1000);
      }

      // ---- export modal ----
      const exportModal = document.getElementById("export");
      const closeExport = () => { exportModal.hidden = true; };
      document.getElementById("tray-export").addEventListener("click", () => {
        if (!bars.some((b) => b.classList.contains("selected"))) return;
        document.getElementById("export-n").textContent =
          bars.filter((b) => b.classList.contains("selected")).length;
        exportModal.hidden = false;
      });
      document.getElementById("export-close").addEventListener("click", closeExport);
      exportModal.addEventListener("click", (e) => { if (e.target === exportModal) closeExport(); });
      document.getElementById("export-ics").addEventListener("click", () => { downloadICS(); closeExport(); });
      document.getElementById("export-pdf").addEventListener("click", () => { closeExport(); startPdf(); });

      // drag-to-scroll the continuous track
      const scroll = document.getElementById("scroll");
      let down = false, startX = 0, startL = 0, moved = 0;
      scroll.addEventListener("pointerdown", (e) => {
        if (e.pointerType !== "mouse") return;   // touch/pen: use native scrolling (don't hijack vertical page scroll)
        if (e.target.closest(".bar")) return;
