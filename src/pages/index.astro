      .vlabel-name { flex: 1; font-size: .8rem; font-weight: 600; color: var(--subtext1); line-height: 1.15;
        overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
      .vlabel.collapsed .vlabel-name { -webkit-line-clamp: 1; }
      .vlabel-count { flex: 0 0 auto; font-size: .68rem; font-weight: 700; color: var(--subtext0); background: var(--surface0); border-radius: 999px; padding: .08rem .42rem; }

      .scroll {
        flex: 1; min-width: 0; overflow-x: auto; overflow-y: hidden; cursor: grab;
        scrollbar-color: var(--surface2) var(--mantle);
      }
      .scroll.grabbing { cursor: grabbing; }
      .scroll::-webkit-scrollbar { height: 12px; }
      .scroll::-webkit-scrollbar-thumb { background: var(--surface2); border-radius: 999px; border: 3px solid var(--mantle); }
      .scroll::-webkit-scrollbar-track { background: var(--mantle); }

      .vband { position: absolute; left: 0; background: transparent; }
      .vband.alt { background: var(--stripe); }
      /* compact "tracks" view: row bands (chart) + row labels (axis) */
      .tband { position: absolute; left: 0; width: 100%; z-index: 0; background: transparent; }
      .tband.alt { background: var(--stripe); }
      .tlabel {
        position: absolute; left: 0; right: 0; display: flex; align-items: center; gap: .35rem;
        padding: 0 .5rem 0 .75rem;
      }
      .tlabel.alt { background: var(--stripe); }

      /* split toolbar: Utility | Select events — side-by-side on desktop, stacked on mobile */
      .toolbars {
        display: flex; align-items: stretch; margin: 0 0 .9rem; overflow: hidden;
        border-radius: .9rem; background: var(--glass); border: 1px solid var(--surface1);
        box-shadow: 0 8px 28px rgba(17,17,27,.35); backdrop-filter: blur(8px);
      }
      .tb-group { display: flex; align-items: center; align-content: flex-start; gap: .7rem; flex-wrap: wrap; padding: .7rem .9rem; }
      .tb-utility { flex: 1 1 340px; }
      .tb-select { flex: 1.6 1 420px; border-left: 1px solid var(--surface1); }
      .tb-head { width: 100%; font-size: .7rem; text-transform: uppercase; letter-spacing: .13em; font-weight: 700; color: var(--overlay1); }
      @media (max-width: 820px) {
        /* stacked + reordered: Select events on top, then the schedule, with Utility
           (view tweaks) tucked underneath the timeline where you adjust them */
        main { display: flex; flex-direction: column; }
        .toolbars { display: contents; }
        .tb-group {
          border-radius: .9rem; background: var(--glass); border: 1px solid var(--surface1);
          box-shadow: 0 8px 28px rgba(17,17,27,.35); backdrop-filter: blur(8px);
        }
        .tb-select   { order: 1; border-left: none; margin: 0 0 .9rem; }
        .scroll-hint { order: 2; }
        .timeline-wrap { order: 3; }
        #empty       { order: 4; }
        .tb-utility  { order: 5; margin: .9rem 0 0; }
      }
      .zoom { display: flex; align-items: center; gap: .45rem; }
      .zoom input { width: 170px; accent-color: var(--mauve); cursor: pointer; }
      .zoom-icon { color: var(--overlay1); font-size: .95rem; }
      .zoom-label { font-size: .8rem; font-weight: 600; color: var(--subtext0); }
      .collapse-all, .view-toggle {
        border: 1px solid var(--surface1); background: var(--surface0); color: var(--subtext1);
        border-radius: 999px; padding: .35rem .85rem; font-size: .8rem; font-weight: 600; cursor: pointer; font-family: inherit;
      }
      .collapse-all:hover, .view-toggle:hover { background: var(--surface1); color: var(--text); }
      .view-toggle { border-color: var(--mauve); color: var(--mauve); }
      .view-toggle:hover { background: color-mix(in srgb, var(--mauve) 18%, var(--mantle)); color: var(--lavender); }

      /* select-by-type checkbox chips */
      .cat-chip {
        display: inline-flex; align-items: center; gap: .35rem; cursor: pointer; user-select: none;
        padding: .28rem .55rem; border-radius: 999px; font-size: .82rem; color: var(--subtext1);
        background: var(--surface0); border: 1px solid var(--surface1); transition: background .12s, border-color .12s;
      }
      .cat-chip:hover { background: var(--surface1); color: var(--text); }
      .cat-chip:has(input:checked) { background: color-mix(in srgb, var(--mauve) 22%, var(--mantle)); border-color: var(--mauve); color: var(--lavender); }
      .cat-chip:has(input:indeterminate) { border-color: var(--mauve); }
      .cat-chip input { accent-color: var(--mauve); cursor: pointer; width: .95rem; height: .95rem; margin: 0; }
      .cat-n { font-size: .68rem; font-weight: 700; color: var(--subtext0); background: rgba(0,0,0,.22); border-radius: 999px; padding: .04rem .38rem; }
      .die { display: inline-block; transform-origin: 50% 55%; }
      .die.rolling { animation: die-roll .55s cubic-bezier(.36,.07,.19,.97) both; }
      @keyframes die-roll {
        0%   { transform: rotate(0deg)    scale(1);   }
        20%  { transform: rotate(-22deg)  scale(1.18);}
        40%  { transform: rotate(18deg)   scale(1.18);}
        60%  { transform: rotate(-14deg)  scale(1.12);}
        80%  { transform: rotate(10deg)   scale(1.06);}
        100% { transform: rotate(0deg)    scale(1);   }
      }
      @media (prefers-reduced-motion: reduce) { .die.rolling { animation: none; } }

      /* "Vibecamp Trials" sparkles — drawn into a click-through overlay that mirrors the
         bar's box and stacks above the foreground; overflow:hidden keeps them inside. */
      .spark-overlay { position: absolute; overflow: hidden; pointer-events: none; z-index: 7; border-radius: .4rem; }
      .sparkle {
        position: absolute; pointer-events: none; z-index: 3; line-height: 1;
        color: var(--yellow); opacity: 0; will-change: transform, opacity;
        text-shadow: 0 0 6px var(--yellow), 0 0 10px color-mix(in srgb, var(--peach) 70%, transparent);
        animation: sparkle-pop 1.4s ease-in-out forwards;
      }
      @keyframes sparkle-pop {
        0%   { opacity: 0;  transform: translateY(4px)  scale(.3) rotate(0deg); }
        30%  { opacity: 1;  transform: translateY(0)    scale(1)  rotate(20deg); }
        70%  { opacity: .9; transform: translateY(-3px) scale(.9) rotate(-10deg); }
        100% { opacity: 0;  transform: translateY(-7px) scale(.2) rotate(15deg); }
      }
      @media (prefers-reduced-motion: reduce) { .sparkle { display: none; } }

      /* glossy sheen for Leah (Prime)'s events + "Welcome to the Vibe Parade" —
         the highlight streak slides as the timeline is scrolled (--sheenx) */
      .bar.sheen::after {
        content: ""; position: absolute; inset: 0; border-radius: inherit;
        pointer-events: none; z-index: 2; mix-blend-mode: screen; opacity: .9;
        background: linear-gradient(105deg,
          transparent 38%,
          color-mix(in srgb, var(--c) 30%, rgba(255,255,255,.85)) 48%,
          rgba(255,255,255,.9) 50%,
          color-mix(in srgb, var(--c) 30%, rgba(255,255,255,.85)) 52%,
          transparent 62%);
        background-size: 320px 100%; background-repeat: repeat;
        background-position-x: var(--sheenx, 0px);
      }

      .chart { position: relative; }
      .daylabels { position: relative; height: 52px; }
      .daylabel {
        position: absolute; top: 8px; height: 40px; padding: 4px 10px;
        display: flex; flex-direction: column; justify-content: center;
        border-left: 2px solid var(--surface2);
      }
      .dl-day { font-size: .95rem; font-weight: 700; color: var(--text); white-space: nowrap; }
      .dl-date { font-size: .76rem; color: var(--peach); }
      .dl-meta { font-size: .68rem; color: var(--overlay1); white-space: nowrap; }

      .ruler { position: relative; height: 22px; }
      .tick {
        position: absolute; top: 4px; transform: translateX(-50%);
        font-size: .68rem; font-variant-numeric: tabular-nums; color: var(--overlay1); white-space: nowrap;
      }

      .lanes { position: relative; margin: 2px 0 14px; }
      .band { position: absolute; top: 0; bottom: 0; background: transparent; }
      .band.alt { background: var(--stripe); }
      .divider { position: absolute; top: -2px; bottom: 0; width: 2px; background: var(--surface1); }
      .grid { position: absolute; top: 0; bottom: 0; width: 1px; background: var(--surface0); opacity: .5; }

      .bar {
        position: absolute; height: 46px; padding: 5px 9px; text-align: left; z-index: 2;
        border: none; border-radius: .55rem; cursor: pointer; overflow: hidden;
        background: color-mix(in srgb, var(--c) 22%, var(--mantle));
        border-left: 3px solid var(--c); color: var(--text); font-family: inherit;
        display: flex; flex-direction: column; justify-content: center; gap: 1px;
        transition: transform .12s, box-shadow .12s, background .12s, opacity .15s;
      }
      .bar:hover {
        background: color-mix(in srgb, var(--c) 34%, var(--mantle));
        transform: translateY(-1px); box-shadow: 0 6px 18px rgba(17,17,27,.55); z-index: 4;
      }
      .bar-time { font-size: .66rem; font-variant-numeric: tabular-nums; color: var(--c); font-weight: 700; line-height: 1; }
      .bar-title { font-size: .8rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.15; }
      .bar.dim { opacity: .1; pointer-events: none; }

      /* multi-day events: span across the day columns with a striped fill + dashed leading edge */
      .bar.multi {
        background:
          repeating-linear-gradient(45deg, transparent 0 9px, color-mix(in srgb, var(--c) 12%, transparent) 9px 18px),
          color-mix(in srgb, var(--c) 20%, var(--mantle));
        border-right: 2px dashed color-mix(in srgb, var(--c) 65%, transparent);
        padding-right: 22px;
      }
      .bar.multi:hover {
        background:
          repeating-linear-gradient(45deg, transparent 0 9px, color-mix(in srgb, var(--c) 16%, transparent) 9px 18px),
          color-mix(in srgb, var(--c) 32%, var(--mantle));
      }
      /* keep the label readable while scrolling along a long bar */
      .bar.multi .bar-time, .bar.multi .bar-title {
        position: sticky; left: 9px; width: max-content; max-width: calc(100% - 18px);
      }
      .bar-cap {
        position: absolute; right: 7px; top: 50%; transform: translateY(-50%);
        font-size: 1rem; font-weight: 800; color: var(--c); line-height: 1;
      }

      /* compact view: long events as a faint hatched background layer (short events sit on top) */
      .bar.bgbar {
        z-index: 1; justify-content: flex-start; padding-top: 5px; border-radius: .4rem;
        background:
          repeating-linear-gradient(45deg, transparent 0 6px, color-mix(in srgb, var(--c) 15%, transparent) 6px 12px),
          color-mix(in srgb, var(--c) 8%, var(--mantle));
        border-left-color: color-mix(in srgb, var(--c) 45%, transparent);
      }
      .bar.bgbar:hover {
        background:
          repeating-linear-gradient(45deg, transparent 0 6px, color-mix(in srgb, var(--c) 22%, transparent) 6px 12px),
          color-mix(in srgb, var(--c) 14%, var(--mantle));
      }
      .bar.bgbar .bar-time, .bar.bgbar .bar-title {
        position: sticky; left: 4px; width: max-content; max-width: calc(100% - 8px);
        color: color-mix(in srgb, var(--c) 72%, var(--subtext0));
      }

      .empty { text-align: center; color: var(--subtext0); padding: 3rem 0; font-size: 1.05rem; }
      footer { border-top: 1px solid var(--surface0); padding: 1.6rem 1.5rem 3rem; text-align: center; }
      footer p { margin: 0; font-size: .82rem; color: var(--overlay0); }

      .panel {
        position: fixed; left: 50%; bottom: 1rem; transform: translateX(-50%);
        width: min(640px, calc(100vw - 2rem)); z-index: 20;
        background: var(--panel-bg); border: 1px solid var(--surface1);
        border-radius: 1rem; padding: 1rem 1.2rem 1.1rem; backdrop-filter: blur(10px);
        box-shadow: 0 16px 48px rgba(17,17,27,.6);
      }
      .panel-close {
        position: absolute; top: .7rem; right: .8rem; background: var(--surface0); border: none;
        color: var(--subtext0); width: 1.7rem; height: 1.7rem; border-radius: 50%; cursor: pointer; font-size: .85rem;
      }
      .panel-close:hover { background: var(--surface1); color: var(--text); }
      .panel h3 { margin: 0 1.8rem .55rem 0; font-size: 1.12rem; color: var(--lavender); }
      .p-meta { display: flex; flex-wrap: wrap; gap: .4rem; margin-bottom: .55rem; }
      .p-chip { font-size: .76rem; padding: .2rem .55rem; border-radius: 999px; background: var(--surface0); color: var(--subtext1); }
      .p-time { color: var(--sky); font-variant-numeric: tabular-nums; }
      .p-org { color: var(--green); }
      .p-loc { color: var(--sapphire); }
      .p-desc { margin: 0; font-size: .9rem; color: var(--subtext0); max-height: 7.5rem; overflow-y: auto; white-space: pre-wrap; }
      .p-toggle {
        margin-top: .8rem; width: 100%; padding: .55rem; border-radius: .6rem;
        border: 1px solid var(--surface1); background: var(--surface0); color: var(--text);
        cursor: pointer; font-weight: 600; font-family: inherit; transition: background .15s, border-color .15s, color .15s;
      }
      .p-toggle:hover { background: var(--surface1); }
      .p-toggle.on { background: color-mix(in srgb, var(--green) 24%, var(--mantle)); border-color: var(--green); color: var(--green); }

      /* selection state on bars */
      .bar-check {
        position: absolute; top: 4px; right: 5px; width: 15px; height: 15px; border-radius: 50%;
        background: var(--green); color: var(--crust); font-size: .62rem; font-weight: 900;
        display: none; align-items: center; justify-content: center; line-height: 1; z-index: 3;
      }
      .bar.selected { outline: 2px solid var(--green); outline-offset: -1px; z-index: 5; }
      /* event you're currently looking at (panel open): glow in its own color */
      .bar.viewing { box-shadow: 0 0 0 2px var(--c), 0 0 16px 2px color-mix(in srgb, var(--c) 65%, transparent); z-index: 6; }
      .bar.selected .bar-check { display: flex; }
      .bar.conflict { outline: 2px solid var(--red); }
      .bar.conflict .bar-check { background: var(--red); }

      /* selection tray */
      .tray {
        position: fixed; top: 1rem; left: 50%; transform: translateX(-50%); z-index: 30;
        display: flex; align-items: center; gap: .7rem;
        background: var(--panel-bg); border: 1px solid var(--surface1);
        border-radius: 999px; padding: .5rem .6rem .5rem 1.1rem;
        box-shadow: 0 12px 40px rgba(17,17,27,.6); backdrop-filter: blur(10px);
        max-width: calc(100vw - 1.5rem);
      }
      .tray-count { font-size: .9rem; color: var(--subtext1); white-space: nowrap; }
      .tray-count b { color: var(--text); }
      .tray-hint { font-size: .82rem; color: var(--overlay1); white-space: nowrap; }
      .tray-min {
        display: none; align-items: center; gap: .25rem; border: none; cursor: pointer; font-family: inherit;
        background: var(--surface0); color: var(--subtext1); border-radius: 999px;
        padding: .3rem .6rem; font-size: .85rem; font-weight: 700;
      }
      .tray-min:hover { background: var(--surface1); color: var(--text); }
      .tray-warn { font-size: .76rem; font-weight: 600; color: var(--crust); background: var(--red); padding: .22rem .6rem; border-radius: 999px; white-space: nowrap; }
      .tray-spacer { flex: 1; min-width: .2rem; }
      .tray-btn { border: none; border-radius: 999px; padding: .45rem .9rem; font-size: .85rem; font-weight: 600; cursor: pointer; font-family: inherit; white-space: nowrap; }
      .tray-btn.ghost { background: var(--surface0); color: var(--subtext1); }
      .tray-btn.ghost:hover { background: var(--surface1); color: var(--text); }
      .tray-btn.primary { background: var(--mauve); color: var(--crust); }
      .tray-btn.primary:hover { background: var(--lavender); }
      .tray-btn:disabled { opacity: .4; cursor: default; pointer-events: none; }
      .tray-check {
        display: inline-flex; align-items: center; gap: .35rem; white-space: nowrap;
        font-size: .82rem; color: var(--subtext1); cursor: pointer; user-select: none;
      }
      .tray-check input { accent-color: var(--mauve); cursor: pointer; width: 1rem; height: 1rem; }

      /* overlap review modal */
      .review {
        position: fixed; inset: 0; z-index: 40; display: flex; align-items: center; justify-content: center;
        background: rgba(17,17,27,.7); backdrop-filter: blur(3px); padding: 1.5rem;
      }
      .review-card {
        position: relative; width: min(560px, 100%); max-height: 82vh; overflow-y: auto;
        background: var(--mantle); border: 1px solid var(--surface1); border-radius: 1rem;
        padding: 1.4rem 1.4rem 1.1rem; box-shadow: 0 24px 64px rgba(17,17,27,.7);
      }
      .review-x {
        position: absolute; top: .9rem; right: 1rem; background: var(--surface0); border: none;
        color: var(--subtext0); width: 1.8rem; height: 1.8rem; border-radius: 50%; cursor: pointer; font-size: .9rem;
      }
      .review-x:hover { background: var(--surface1); color: var(--text); }
      .review-card h3 { margin: 0 1.8rem .4rem 0; font-size: 1.2rem; color: var(--lavender); }
      .review-sub { margin: 0 0 1rem; font-size: .9rem; color: var(--subtext0); }
      .review-list { display: flex; flex-direction: column; gap: .55rem; }
      .rv-row {
        display: flex; align-items: center; gap: .8rem; padding: .65rem .8rem;
        background: var(--base); border: 1px solid var(--surface0); border-left: 3px solid var(--red); border-radius: .6rem;
      }
      .rv-info { flex: 1; min-width: 0; }
      .rv-pair { font-size: .9rem; font-weight: 600; color: var(--text); }
      .rv-times { font-size: .78rem; color: var(--subtext0); font-variant-numeric: tabular-nums; margin-top: .15rem; }
      .rv-ok {
        flex: 0 0 auto; border: 1px solid var(--surface1); background: var(--surface0); color: var(--subtext1);
        border-radius: 999px; padding: .4rem .85rem; font-size: .82rem; font-weight: 600; cursor: pointer; font-family: inherit;
      }
      .rv-ok:hover { background: var(--surface1); color: var(--text); }
      .rv-ok.on { background: color-mix(in srgb, var(--green) 26%, var(--mantle)); border-color: var(--green); color: var(--green); }
      .rv-row.resolved { border-left-color: var(--green); }
      .review-actions { display: flex; align-items: center; gap: .6rem; margin-top: 1.2rem; }
      .rv-btn { border: none; border-radius: 999px; padding: .5rem 1rem; font-size: .85rem; font-weight: 600; cursor: pointer; font-family: inherit; }
      .rv-btn.ghost { background: var(--surface0); color: var(--subtext1); }
      .rv-btn.ghost:hover { background: var(--surface1); color: var(--text); }
      .rv-btn.primary { background: var(--mauve); color: var(--crust); }
      .rv-btn.primary:hover { background: var(--lavender); }

      /* export modal: two big choice cards + a PDF-map toggle */
      .export-opts { display: flex; flex-direction: column; gap: .6rem; }
      .export-opt { display: flex; align-items: flex-start; gap: .8rem; text-align: left; width: 100%; padding: .85rem 1rem; border: 1px solid var(--surface1); border-radius: 14px; background: var(--surface0); color: var(--text); cursor: pointer; font-family: inherit; transition: border-color .12s, background .12s, transform .06s; }
      .export-opt:hover { background: var(--surface1); border-color: var(--mauve); }
      .export-opt:active { transform: translateY(1px); }
      .export-emoji { font-size: 1.5rem; line-height: 1.4; flex: none; }
      .export-txt { display: flex; flex-direction: column; gap: .2rem; }
      .export-txt b { font-size: .98rem; }
      .export-txt small { font-size: .82rem; color: var(--subtext0); line-height: 1.35; }
      .export-txt code { background: var(--mantle); padding: 0 .25rem; border-radius: 4px; font-size: .9em; }
      .export-mapchk { display: flex; align-items: center; gap: .45rem; margin: .9rem .15rem 0; font-size: .85rem; color: var(--subtext1); cursor: pointer; }
      .export-mapchk input { accent-color: var(--mauve); }
      .howto-body { margin: .2rem 0 0; padding-left: 1.15rem; display: flex; flex-direction: column; gap: .6rem; font-size: .9rem; color: var(--subtext0); line-height: 1.45; }
      .howto-body b { color: var(--text); font-weight: 600; }
      .howto-divider { border-top: 1px solid var(--surface1); margin: 1.15rem 0 .85rem; }
      .howto-subhead { margin: 0 0 .65rem; font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; font-weight: 700; color: var(--overlay1); }
      .mapcard { width: min(980px, 100%); }
      .mapfull { display: block; width: 100%; height: auto; margin-top: .4rem; border-radius: .6rem; border: 1px solid var(--surface1); }

      /* printable schedule — hidden on screen, revealed when printing */
      .print-schedule { display: none; }
      @media print {
        /* Catppuccin Latte — the light sibling of the Mocha screen theme */
        .aurora, .hero, main, footer, #panel, #tray, #review { display: none !important; }
        html, body { background: #fff !important; }
        @page { margin: 13mm; }

        .print-schedule {
          display: block !important; max-width: 720pt; margin: 0 auto;
          color: #4c4f69; font-family: "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
          -webkit-print-color-adjust: exact; print-color-adjust: exact;
        }

        /* header */
        .ps-head {
          display: flex; align-items: center; gap: 14pt;
          padding-bottom: 12pt; margin-bottom: 15pt; border-bottom: 1.5pt solid #8839ef;
        }
        .ps-logo { width: 50pt; height: 50pt; border-radius: 11pt; flex: 0 0 auto; }
        .ps-headtext { min-width: 0; }
        .ps-kicker { margin: 0 0 2pt; font-size: 8pt; letter-spacing: .22em; text-transform: uppercase; color: #8839ef; font-weight: 700; }
        .ps-head h1 { margin: 0; font-size: 23pt; font-weight: 800; letter-spacing: -.02em; color: #4c4f69; }
        .ps-sub { margin: 3pt 0 0; font-size: 9.5pt; color: #8c8fa1; }

        /* unresolved-conflict notice */
        .ps-warn { margin-bottom: 15pt; font-size: 9pt; }
        .pw-red { border: 1pt solid #f0a9b8; background: #fce7ec; color: #b30f33; border-radius: 8pt; padding: 9pt 12pt; }
        .ps-warn h4 { margin: 0 0 5pt; font-size: 10pt; font-weight: 700; }
        .ps-warn div { margin: 1.5pt 0; color: #9c2440; }

        /* day groups */
        /* let a day flow across a page break (items below avoid splitting individually);
           avoiding the break on the whole day is what left big gaps when one didn't fit */
        .ps-day { margin-bottom: 15pt; }
        .ps-day h2 { display: flex; align-items: baseline; gap: 8pt; margin: 0 0 5pt; padding-bottom: 4pt; border-bottom: 1pt solid #e6e9ef; break-after: avoid; }
        .ps-dayname { font-size: 13pt; font-weight: 700; letter-spacing: -.01em; color: #8839ef; }
        .ps-daycount { margin-left: auto; font-size: 8pt; font-weight: 600; color: #9ca0b0; }

        /* event rows */
        .ps-item { display: flex; gap: 11pt; align-items: flex-start; padding: 7pt 0; border-bottom: .75pt solid #eff1f5; break-inside: avoid; }
        .ps-item:last-child { border-bottom: none; }
        .ps-time {
          flex: 0 0 88pt; font-variant-numeric: tabular-nums; font-weight: 700; font-size: 8.5pt;
          color: #8839ef; background: #f1e9fb; border-radius: 6pt; padding: 4pt 6pt; text-align: center; line-height: 1.25;
        }
        .ps-main { flex: 1; padding-top: .5pt; }
        .ps-main .t { font-weight: 700; font-size: 10.5pt; line-height: 1.25; color: #4c4f69; }
        .ps-main .m { margin-top: 2.5pt; font-size: 8.5pt; color: #8c8fa1; }
        .ps-host { font-style: italic; }
        .ps-loc { color: #6c6f85; }
        .ps-dot { margin: 0 5pt; color: #bcc0cc; }

        /* conflicts */
        .ps-item.conflict .ps-time { color: #d20f39; background: #fce7ec; }
        .ps-item.conflict .t::after { content: "  ⚠ overlaps"; color: #d20f39; font-weight: 700; font-size: 7.5pt; letter-spacing: .02em; }

        .ps-foot { margin-top: 18pt; padding-top: 8pt; border-top: 1pt solid #e6e9ef; font-size: 7.5pt; color: #acb0be; text-align: center; }

        /* camp map — at the top of the PDF, before the schedule */
        .ps-map { margin: 0 0 16pt; text-align: center; break-inside: avoid; }
        .ps-map-h { margin: 0 0 6pt; font-size: 13pt; font-weight: 700; letter-spacing: -.01em; color: #8839ef; }
        .ps-map img { max-width: 100%; height: auto; border-radius: 8pt; border: 1pt solid #e6e9ef; }
      }

      @media (max-width: 560px) {
        .hero { padding-top: 2.6rem; }
        /* narrower row-track headers on mobile so the timeline gets the space */
        .vaxis { flex-basis: 96px; }
        .vaxis-head { padding: 0 .5rem .5rem; font-size: .6rem; letter-spacing: .06em; }
        .vlabel { padding: 0 .4rem; gap: .25rem; }
        .vlabel-count { font-size: .62rem; padding: .06rem .34rem; }
        /* schedule-manager bar: span the width and wrap its controls instead of running off-screen.
           Starts hidden (so it doesn't overlap the title) and fades in on first downscroll. */
        .tray {
          top: .6rem; left: .6rem; right: .6rem; max-width: none;
          flex-wrap: wrap; justify-content: center; border-radius: .9rem; padding: .55rem .65rem; gap: .4rem .5rem;
          opacity: 0; transform: translateY(0); pointer-events: none;
          transition: opacity .4s ease, transform .38s ease;
        }
        .tray.revealed { opacity: 1; pointer-events: auto; }
        .tray-spacer { display: none; }
        .tray-hint { white-space: normal; }
        /* pull-tab hanging off the bottom of the bar; when collapsed the bar slides up
           off the top and the tab is left hanging from the top edge of the window */
        .tray-min {
          display: inline-flex; align-items: center; justify-content: center;
          position: absolute; left: 50%; bottom: -23px; transform: translateX(-50%);
          width: 66px; height: 24px; padding: 0; border-radius: 0 0 .8rem .8rem;
          background: var(--panel-bg); border: 1px solid var(--surface1); border-top: none;
          color: var(--subtext1); font-size: .95rem; line-height: 1;
          box-shadow: 0 8px 16px rgba(17,17,27,.5);
        }
        .tray.collapsed { transform: translateY(calc(-100% - .6rem)); }
      }
    </style>
  </body>
</html>
