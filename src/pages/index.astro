---
// Landing page: pick between the event schedule and the Vibecamp Trials.
// The scheduler lives at /schedule/, the Trials at /trials/.
---

<!doctype html>
<html lang="en" data-theme="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Vibecamp 5 · June 18–21, 2026</title>
    <meta name="description" content="Vibecamp 5 at Camp Ramblewood, MD — the event schedule and the Vibecamp Trials." />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/vibecamp_logo.png" />
    <link rel="apple-touch-icon" href="/vibecamp_logo.png" />
    <meta property="og:title" content="Vibecamp 5" />
    <meta property="og:description" content="June 18–21, 2026 · Camp Ramblewood, MD. Browse the schedule or enter the Trials." />
    <meta property="og:image" content="https://vibecamp.mahan.io/vibecamp_logo.png" />
    <meta name="twitter:card" content="summary" />
    <script is:inline>
      // set theme before first paint to avoid a flash of the wrong palette
      (function () {
        var t = "system";
        try { t = localStorage.getItem("vc-theme") || "system"; } catch (e) {}
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
  </head>
  <body>
    <div class="aurora"></div>

    <main class="land">
      <header class="land-hero">
        <img class="land-logo" src="/vibecamp_logo.png" alt="" />
        <p class="kicker">✦ Vibe Camp</p>
        <h1>Vibecamp&nbsp;5</h1>
        <p class="land-sub">June 18–21, 2026 · Camp Ramblewood, MD</p>
      </header>

      <nav class="choices" aria-label="Site sections">
        <a class="choice" href="/schedule/">
          <span class="choice-emoji" aria-hidden="true">🗓</span>
          <span class="choice-title">Event Schedule</span>
          <span class="choice-desc">
            Every event on one continuous timeline. Build your personal schedule,
            check overlaps, and send it to your calendar.
          </span>
          <span class="choice-go" aria-hidden="true">Browse the timeline →</span>
        </a>

        <a class="choice choice-trials" href="/trials/">
          <span class="choice-spark" aria-hidden="true"><i>✦</i><i>✧</i><i>⋆</i><i>✶</i><i>✧</i><i>✦</i></span>
          <span class="choice-emoji" aria-hidden="true">🏆</span>
          <span class="choice-title">Vibecamp Trials</span>
          <span class="choice-desc">
            The camp-wide game running all weekend. Find out how to play,
            where to turn in, and what glory awaits.
          </span>
          <span class="choice-go" aria-hidden="true">Enter the Trials →</span>
        </a>
      </nav>
    </main>

    <footer class="land-foot">
      <p>Send bugs to <a href="https://twitter.com/timebard" target="_blank" rel="noopener">@timebard</a> on twitter!</p>
    </footer>

    <style is:global>
      /* --- dark (Catppuccin Mocha) — the default --- */
      :root {
        color-scheme: dark;
        --base: #1e1e2e; --mantle: #181825; --crust: #11111b;
        --surface0: #313244; --surface1: #45475a; --surface2: #585b70;
        --overlay0: #6c7086; --overlay1: #7f849c; --overlay2: #9399b2;
        --text: #cdd6f4; --subtext1: #bac2de; --subtext0: #a6adc8;
        --blue: #89b4fa; --lavender: #b4befe; --sapphire: #74c7ec;
        --sky: #89dceb; --teal: #94e2d5; --green: #a6e3a1;
        --yellow: #f9e2af; --peach: #fab387; --maroon: #eba0ac;
        --red: #f38ba8; --mauve: #cba6f7; --pink: #f5c2e7;
        --card: rgba(24,24,37,.66);
      }
      /* --- light (Catppuccin Latte) — explicit choice + system-follows-OS --- */
      :root[data-theme="light"],
      :root[data-theme="system"] { color-scheme: light dark; }
      @media (prefers-color-scheme: light) {
        :root[data-theme="system"] {
          color-scheme: light;
          --base: #eff1f5; --mantle: #e6e9ef; --crust: #dce0e8;
          --surface0: #ccd0da; --surface1: #bcc0cc; --surface2: #acb0be;
          --overlay0: #9ca0b0; --overlay1: #8c8fa1; --overlay2: #7c7f93;
          --text: #4c4f69; --subtext1: #5c5f77; --subtext0: #6c6f85;
          --blue: #1e66f5; --lavender: #7287fd; --sapphire: #209fb5;
          --sky: #04a5e5; --teal: #179299; --green: #40a02b;
          --yellow: #df8e1d; --peach: #fe640b; --maroon: #e64553;
          --red: #d20f39; --mauve: #8839ef; --pink: #ea76cb;
          --card: rgba(230,233,239,.78);
        }
      }
      :root[data-theme="light"] {
        color-scheme: light;
        --base: #eff1f5; --mantle: #e6e9ef; --crust: #dce0e8;
        --surface0: #ccd0da; --surface1: #bcc0cc; --surface2: #acb0be;
        --overlay0: #9ca0b0; --overlay1: #8c8fa1; --overlay2: #7c7f93;
        --text: #4c4f69; --subtext1: #5c5f77; --subtext0: #6c6f85;
        --blue: #1e66f5; --lavender: #7287fd; --sapphire: #209fb5;
        --sky: #04a5e5; --teal: #179299; --green: #40a02b;
        --yellow: #df8e1d; --peach: #fe640b; --maroon: #e64553;
        --red: #d20f39; --mauve: #8839ef; --pink: #ea76cb;
        --card: rgba(230,233,239,.78);
      }

      * { box-sizing: border-box; }
      html, body { height: 100%; }
      body {
        margin: 0; background: var(--base); color: var(--text);
        font-family: "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        line-height: 1.5; -webkit-font-smoothing: antialiased;
        display: flex; flex-direction: column;
      }
      .aurora {
        position: fixed; inset: 0; z-index: -1;
        background:
          radial-gradient(55% 45% at 12% 0%, rgba(203,166,247,.18), transparent 70%),
          radial-gradient(50% 40% at 92% 4%, rgba(137,180,250,.16), transparent 70%),
          radial-gradient(60% 50% at 50% 100%, rgba(148,226,213,.10), transparent 70%);
      }

      .land {
        flex: 1; width: 100%; max-width: 880px; margin: 0 auto;
        padding: 4.5rem 1.5rem 2rem; text-align: center;
        display: flex; flex-direction: column; justify-content: center; gap: 2.4rem;
      }
      .land-logo { width: 96px; height: 96px; object-fit: contain; margin: 0 auto .9rem; display: block; }
      .kicker { margin: 0 0 .5rem; font-size: .85rem; letter-spacing: .28em; text-transform: uppercase; color: var(--mauve); font-weight: 600; }
      .land-hero h1 {
        margin: 0; font-size: clamp(2.4rem, 6vw, 3.6rem); letter-spacing: -.02em;
        background: linear-gradient(120deg, var(--mauve), var(--blue) 55%, var(--teal));
        -webkit-background-clip: text; background-clip: text; color: transparent;
      }
      .land-sub { margin: .6rem 0 0; color: var(--subtext0); font-size: 1.05rem; }

      .choices { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
      @media (max-width: 640px) { .choices { grid-template-columns: 1fr; } }

      .choice {
        position: relative; overflow: hidden; text-decoration: none; color: var(--text);
        background: var(--card); border: 1px solid var(--surface0); border-radius: 1rem;
        padding: 1.8rem 1.5rem 1.5rem; text-align: left;
        display: flex; flex-direction: column; gap: .55rem;
        transition: transform .14s, box-shadow .14s, border-color .14s;
      }
      .choice:hover, .choice:focus-visible {
        transform: translateY(-3px);
        box-shadow: 0 14px 38px rgba(17,17,27,.45);
        border-color: var(--mauve);
      }
      .choice-emoji { font-size: 2rem; line-height: 1; }
      .choice-title { font-size: 1.35rem; font-weight: 700; }
      .choice-desc { color: var(--subtext0); font-size: .95rem; }
      .choice-go { margin-top: auto; padding-top: .6rem; color: var(--blue); font-weight: 600; font-size: .95rem; }
      .choice-trials:hover, .choice-trials:focus-visible { border-color: var(--yellow); }
      .choice-trials .choice-go { color: var(--yellow); }

      /* ambient sparkles on the Trials card */
      .choice-spark { position: absolute; inset: 0; pointer-events: none; }
      .choice-spark i {
        position: absolute; font-style: normal; color: var(--yellow); opacity: 0;
        animation: land-spark 3.2s ease-in-out infinite;
      }
      .choice-spark i:nth-child(1) { top: 12%; left: 8%;  font-size: .8rem;  animation-delay: 0s; }
      .choice-spark i:nth-child(2) { top: 22%; left: 86%; font-size: .65rem; animation-delay: .6s; }
      .choice-spark i:nth-child(3) { top: 68%; left: 14%; font-size: .7rem;  animation-delay: 1.2s; }
      .choice-spark i:nth-child(4) { top: 80%; left: 78%; font-size: .85rem; animation-delay: 1.8s; }
      .choice-spark i:nth-child(5) { top: 44%; left: 50%; font-size: .6rem;  animation-delay: 2.4s; }
      .choice-spark i:nth-child(6) { top: 8%;  left: 55%; font-size: .7rem;  animation-delay: 3s; }
      @keyframes land-spark {
        0%, 100% { opacity: 0; transform: scale(.4) rotate(0deg); }
        50%      { opacity: .9; transform: scale(1) rotate(40deg); }
      }
      @media (prefers-reduced-motion: reduce) {
        .choice-spark i { animation: none; opacity: .35; }
        .choice { transition: none; }
      }

      .land-foot { padding: 1.4rem 1.5rem 2.4rem; text-align: center; }
      .land-foot p { margin: 0; font-size: .82rem; color: var(--overlay0); }
      .land-foot a { color: var(--blue); }
    </style>
  </body>
</html>
