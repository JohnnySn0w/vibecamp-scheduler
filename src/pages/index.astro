---
// Landing page: pick between the event schedule and the Vibecamp Trials.
// The scheduler lives at /schedule/, the Trials at /trials/.
---

<!doctype html>
<html lang="en" data-theme="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Vibecamp 5 · June 18–21, 2026</title>
    <meta name="description" content="Vibecamp 5 at Camp Ramblewood, MD — the event schedule and the Vibecamp Trials." />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/vibecamp_logo.png" />
    <link rel="apple-touch-icon" href="/vibecamp_logo.png" />
    <meta property="og:title" content="Vibecamp 5" />
    <meta property="og:description" content="June 18–21, 2026 · Camp Ramblewood, MD. Browse the schedule or enter the Trials." />
    <meta property="og:image" content="https://vibecamp.mahan.io/vibecamp_logo.png" />
    <meta name="twitter:card" content="summary" />
    <script is:inline>
      // set theme before first paint to avoid a flash of the wrong palette
      (function () {
        var t = "system";
        try { t = localStorage.getItem("vc-theme") || "system"; } catch (e) {}
        document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
  </head>
  <body>
    <div class="aurora"></div>

    <main class="land">
      <header class="land-hero">
        <h1 class="sr-only">Vibecamp 5</h1>
        <figure class="polaroid">
          <img class="land-logo" src="/vibecamp_logo.png" alt="" />
          <figcaption>
            <span class="scratch"><s>Fivecamp</s> <s>5camp</s></span>
            vibecamp 5 ✦
          </figcaption>
        </figure>
        <p class="land-sub">June 18–21, 2026 · Camp Ramblewood, MD</p>
      </header>

      <span class="land-stars" aria-hidden="true"><i>✦</i><i>✧</i><i>⋆</i><i>✶</i><i>✧</i></span>

      <div class="board">
        <nav class="choices" aria-label="Site sections">
          <a class="choice" href="/schedule/" style="--ac: var(--blue); --tilt: -1.9deg">
            <span class="choice-emoji" aria-hidden="true">🗓</span>
            <span class="choice-title">Event Schedule</span>
            <span class="choice-desc">
              Every event on one continuous timeline. Build your personal schedule,
              check overlaps, and send it to your calendar.
            </span>
            <span class="choice-go" aria-hidden="true">Browse the timeline →</span>
          </a>

          <a class="choice choice-trials" href="/trials/" style="--ac: var(--yellow); --tilt: 1.6deg">
            <span class="choice-spark" aria-hidden="true"><i>✦</i><i>✧</i><i>⋆</i><i>✶</i><i>✧</i><i>✦</i></span>
            <span class="choice-emoji" aria-hidden="true">🏆</span>
            <span class="choice-title">Vibecamp Trials</span>
            <span class="choice-desc">
              The camp-wide game running all weekend. Find out how to play,
              where to turn in, and what glory awaits.
            </span>
            <span class="choice-go" aria-hidden="true">Enter the Trials →</span>
          </a>
        </nav>
        <p class="sticky" aria-hidden="true">bring water, sunscreen,<br />and vibes ☀</p>
      </div>
    </main>

    <footer class="land-foot">
      <p>Send bugs to <a href="https://twitter.com/timebard" target="_blank" rel="noopener">@timebard</a> on twitter!</p>
    </footer>

    <style is:global>
      /* --- dark (Catppuccin Mocha) — the default --- */
      :root {
        color-scheme: dark;
        --base: #1e1e2e; --mantle: #181825; --crust: #11111b;
        --surface0: #313244; --surface1: #45475a; --surface2: #585b70;
        --overlay0: #6c7086; --overlay1: #7f849c; --overlay2: #9399b2;
        --text: #cdd6f4; --subtext1: #bac2de; --subtext0: #a6adc8;
        --blue: #89b4fa; --lavender: #b4befe; --sapphire: #74c7ec;
        --sky: #89dceb; --teal: #94e2d5; --green: #a6e3a1;
        --yellow: #f9e2af; --peach: #fab387; --maroon: #eba0ac;
        --red: #f38ba8; --mauve: #cba6f7; --pink: #f5c2e7;
        --card: rgba(24,24,37,.66);
        --cork1: #6b4f33; --cork2: #58412a; --cork-frame: #4a3520;
        --hand: "Segoe Print", "Bradley Hand", "Comic Sans MS", cursive;
      }
      /* --- light (Catppuccin Latte) — explicit choice + system-follows-OS --- */
      :root[data-theme="light"],
      :root[data-theme="system"] { color-scheme: light dark; }
      @media (prefers-color-scheme: light) {
        :root[data-theme="system"] {
          color-scheme: light;
          --base: #eff1f5; --mantle: #e6e9ef; --crust: #dce0e8;
          --surface0: #ccd0da; --surface1: #bcc0cc; --surface2: #acb0be;
          --overlay0: #9ca0b0; --overlay1: #8c8fa1; --overlay2: #7c7f93;
          --text: #4c4f69; --subtext1: #5c5f77; --subtext0: #6c6f85;
          --blue: #1e66f5; --lavender: #7287fd; --sapphire: #209fb5;
          --sky: #04a5e5; --teal: #179299; --green: #40a02b;
          --yellow: #df8e1d; --peach: #fe640b; --maroon: #e64553;
          --red: #d20f39; --mauve: #8839ef; --pink: #ea76cb;
          --card: rgba(230,233,239,.78);
          --cork1: #c49a68; --cork2: #b18a5b; --cork-frame: #7c5c38;
        }
      }
      :root[data-theme="light"] {
        color-scheme: light;
        --base: #eff1f5; --mantle: #e6e9ef; --crust: #dce0e8;
        --surface0: #ccd0da; --surface1: #bcc0cc; --surface2: #acb0be;
        --overlay0: #9ca0b0; --overlay1: #8c8fa1; --overlay2: #7c7f93;
        --text: #4c4f69; --subtext1: #5c5f77; --subtext0: #6c6f85;
        --blue: #1e66f5; --lavender: #7287fd; --sapphire: #209fb5;
        --sky: #04a5e5; --teal: #179299; --green: #40a02b;
        --yellow: #df8e1d; --peach: #fe640b; --maroon: #e64553;
        --red: #d20f39; --mauve: #8839ef; --pink: #ea76cb;
        --card: rgba(230,233,239,.78);
        --cork1: #c49a68; --cork2: #b18a5b; --cork-frame: #7c5c38;
      }

      * { box-sizing: border-box; }
      html, body { height: 100%; overflow-x: clip; }
      body {
        margin: 0; background: var(--base); color: var(--text);
        font-family: "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        line-height: 1.5; -webkit-font-smoothing: antialiased;
        display: flex; flex-direction: column;
      }
      .aurora {
        position: fixed; inset: 0; z-index: -1;
        background:
          radial-gradient(55% 45% at 12% 0%, rgba(203,166,247,.18), transparent 70%),
          radial-gradient(50% 40% at 92% 4%, rgba(137,180,250,.16), transparent 70%),
          radial-gradient(60% 50% at 50% 100%, rgba(148,226,213,.10), transparent 70%);
      }

      .land {
        flex: 1; width: 100%; max-width: 880px; margin: 0 auto;
        padding: 4.5rem 1.5rem 2rem; text-align: center;
        display: flex; flex-direction: column; justify-content: center; gap: 2.4rem;
      }
      .land-logo { width: 96px; height: 96px; object-fit: contain; margin: 0 auto .9rem; display: block; }
      .kicker { margin: 0 0 .5rem; font-size: .85rem; letter-spacing: .28em; text-transform: uppercase; color: var(--mauve); font-weight: 600; }
      .land-hero h1 {
        margin: 0; font-size: clamp(2.4rem, 6vw, 3.6rem); letter-spacing: -.02em;
        background: linear-gradient(120deg, var(--mauve), var(--blue) 55%, var(--teal));
        -webkit-background-clip: text; background-clip: text; color: transparent;
      }
      .land-sub { margin: .6rem 0 0; color: var(--subtext0); font-size: 1.05rem; }

      /* the cork message board */
      .board {
        position: relative; border-radius: 8px;
        padding: 2.4rem 1.8rem 2.2rem;
        background:
          radial-gradient(rgba(0,0,0,.16) 1px, transparent 1.5px),
          radial-gradient(rgba(255,236,200,.06) 1px, transparent 1.6px),
          radial-gradient(rgba(0,0,0,.10) 1.3px, transparent 1.9px),
          linear-gradient(135deg, var(--cork1), var(--cork2));
        background-size: 9px 11px, 15px 17px, 22px 19px, 100% 100%;
        background-position: 0 0, 5px 8px, 11px 3px, 0 0;
        border: 10px solid var(--cork-frame);
        box-shadow:
          inset 0 2px 18px rgba(0,0,0,.45),
          inset 0 0 0 2px rgba(0,0,0,.2),
          0 14px 38px rgba(17,17,27,.4);
        /* rasterize the cork once on its own layer (perf) */
        transform: translateZ(0);
      }
      @media (max-width: 640px) { .board { padding: 2rem 1rem 1.8rem; border-width: 8px; } }

      .sr-only {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
      }

      /* the logo as a pinned polaroid — now the hero itself */
      .polaroid {
        display: inline-block; margin: 0 auto .4rem;
        background: #f4f1ea; padding: 12px 12px 8px;
        transform: rotate(-3deg);
        box-shadow: 0 8px 22px rgba(0,0,0,.4);
        position: relative;
      }
      .polaroid::before {
        content: ""; position: absolute; top: -7px; left: 50%; margin-left: -7px;
        width: 14px; height: 14px; border-radius: 50%;
        background: radial-gradient(circle at 35% 30%, #f8b4c0, #e8516d 55%, #8e2236);
        box-shadow: 0 3px 4px rgba(0,0,0,.4);
      }
      .polaroid .land-logo { margin: 0; width: 128px; height: 128px; }
      .polaroid figcaption {
        font-family: var(--hand); font-size: 1.05rem; color: #4a4438;
        padding-top: 5px; line-height: 1.25;
      }
      .polaroid .scratch { display: block; font-size: .8rem; color: #8a7f6a; }
      .polaroid .scratch s { text-decoration-thickness: 2px; margin: 0 .2rem; }

      /* a scrawled sticky note on the board */
      .sticky {
        width: max-content; max-width: 80%;
        margin: 1.4rem auto 0; padding: .7rem 1.1rem .85rem;
        background: linear-gradient(160deg, #f7e7a8, #efd989);
        color: #43381c; font-family: var(--hand); font-size: .95rem; line-height: 1.35;
        transform: rotate(2deg);
        box-shadow: 0 6px 16px rgba(0,0,0,.35);
        border-bottom-right-radius: 60% 12px;
      }

      .choices { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem 1.2rem; }
      @media (max-width: 640px) { .choices { grid-template-columns: 1fr; } }

      /* cards as flyers pinned at a slight angle, taped at the top */
      .choice {
        position: relative; text-decoration: none; color: var(--text);
        background: var(--card); border: 1px solid var(--surface0); border-radius: 1rem;
        padding: 2rem 1.5rem 1.5rem; text-align: left;
        display: flex; flex-direction: column; gap: .55rem;
        transform: rotate(var(--tilt, 0deg));
        transition: transform .18s, box-shadow .18s, border-color .18s;
      }
      .choice::before {
        content: ""; position: absolute; top: -8px; left: 50%; margin-left: -8px;
        width: 16px; height: 16px; border-radius: 50%;
        background: radial-gradient(circle at 35% 30%,
          color-mix(in srgb, var(--ac) 45%, white),
          var(--ac) 55%,
          color-mix(in srgb, var(--ac) 55%, black));
        box-shadow: 0 3px 4px rgba(0,0,0,.45), inset 0 -1px 2px rgba(0,0,0,.3);
        z-index: 2;
      }
      .choice:hover, .choice:focus-visible {
        transform: rotate(0deg) translateY(-5px) scale(1.015);
        box-shadow: 0 16px 42px color-mix(in srgb, var(--ac) 18%, rgba(17,17,27,.5));
        border-color: var(--ac);
      }
      .choice-emoji {
        font-size: 2.6rem; line-height: 1; width: max-content;
        transform: rotate(-8deg); filter: drop-shadow(0 3px 6px rgba(17,17,27,.4));
        transition: transform .18s;
      }
      .choice:hover .choice-emoji { transform: rotate(6deg) scale(1.12); }
      .choice-title { font-family: var(--hand); font-size: 1.45rem; font-weight: 700; }
      .choice-desc { color: var(--subtext0); font-size: .95rem; }
      .choice-go { margin-top: auto; padding-top: .6rem; color: var(--ac, var(--blue)); font-weight: 600; font-size: .95rem; font-family: var(--hand); }

      /* a few stars drifting between the hero and the cards */
      .land-stars { position: relative; display: block; height: 0; }
      .land-stars i {
        position: absolute; font-style: normal; color: var(--mauve); opacity: .4;
        animation: land-drift 6s ease-in-out infinite;
      }
      .land-stars i:nth-child(1) { left: 6%;  top: -3.2rem; font-size: .8rem; }
      .land-stars i:nth-child(2) { left: 22%; top: -1rem;   font-size: .6rem; color: var(--teal); animation-delay: 1.2s; }
      .land-stars i:nth-child(3) { left: 55%; top: -2.4rem; font-size: .7rem; color: var(--yellow); animation-delay: 2.4s; }
      .land-stars i:nth-child(4) { left: 78%; top: -.8rem;  font-size: .9rem; animation-delay: 3.6s; }
      .land-stars i:nth-child(5) { left: 93%; top: -2.8rem; font-size: .6rem; color: var(--sky); animation-delay: 4.8s; }
      @keyframes land-drift {
        0%, 100% { transform: translateY(0) scale(1); opacity: .35; }
        50%      { transform: translateY(-7px) scale(1.15); opacity: .75; }
      }
      @media (prefers-reduced-motion: reduce) { .land-stars i { animation: none; } }

      /* ambient sparkles on the Trials card */
      .choice-spark { position: absolute; inset: 0; pointer-events: none; }
      .choice-spark i {
        position: absolute; font-style: normal; color: var(--yellow); opacity: 0;
        animation: land-spark 3.2s ease-in-out infinite;
      }
      .choice-spark i:nth-child(1) { top: 12%; left: 8%;  font-size: .8rem;  animation-delay: 0s; }
      .choice-spark i:nth-child(2) { top: 22%; left: 86%; font-size: .65rem; animation-delay: .6s; }
      .choice-spark i:nth-child(3) { top: 68%; left: 14%; font-size: .7rem;  animation-delay: 1.2s; }
      .choice-spark i:nth-child(4) { top: 80%; left: 78%; font-size: .85rem; animation-delay: 1.8s; }
      .choice-spark i:nth-child(5) { top: 44%; left: 50%; font-size: .6rem;  animation-delay: 2.4s; }
      .choice-spark i:nth-child(6) { top: 8%;  left: 55%; font-size: .7rem;  animation-delay: 3s; }
      @keyframes land-spark {
        0%, 100% { opacity: 0; transform: scale(.4) rotate(0deg); }
        50%      { opacity: .9; transform: scale(1) rotate(40deg); }
      }
      @media (prefers-reduced-motion: reduce) {
        .choice-spark i { animation: none; opacity: .35; }
        .choice { transition: none; }
      }

      .land-foot { padding: 1.4rem 1.5rem 2.4rem; text-align: center; }
      .land-foot p { margin: 0; font-size: .82rem; color: var(--overlay0); }
      .land-foot a { color: var(--blue); }
    </style>
  </body>
</html>
