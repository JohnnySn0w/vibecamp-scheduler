---
// Badge gallery — the five Trials badges rendered as 3D-tilting physical badges.
// Each badge is an inline SVG: the real laser cut-line path (extracted from the
// production .ai) filled white like the acrylic blank, with the engraving art
// (transparent PNG) clipped to it. CSS drop-shadow follows the arch shape, and
// a pointer-tracking tilt + gloss gives the 3D feel.
import TrialsLayout from "../../layouts/TrialsLayout.astro";
const crumbs = [
  { href: "/trials/", label: "← Trials" },
  { href: "/schedule/", label: "Event schedule →" },
];

// the cut shape, in card coordinates (155.91 × 240.95 pt)
const CUT =
  "M0.00 162.99 L0.00 6.92 C0.00 3.10 3.10 0.00 6.92 0.00 L148.99 0.00 " +
  "C152.81 0.00 155.91 3.10 155.91 6.92 L155.91 162.99 " +
  "C155.91 206.04 121.01 240.95 77.95 240.95 C34.90 240.95 0.00 206.04 0.00 162.99 Z";
const W = 155.91, H = 240.95;

const BADGES = [
  { file: "map-territory",            title: "The Map Is Not the Territory" },
  { file: "mpot-ypot",                title: "MPOT Is Not YPOT" },
  { file: "ycjdt-take-me",            title: "YCJDT!" },
  { file: "post-rat",                 title: "Post Rat" },
  { file: "friendly-ambitious-nerds", title: "Friendly Ambitious Nerds" },
];
---

<TrialsLayout
  title="Badges · Vibecamp Trials"
  description="The five Vibecamp Trials badges — earn them all."
  crumbs={crumbs}
>
  <header class="trials-hero">
    <p class="kicker">✦ Vibecamp Trials</p>
    <h1>The Badges</h1>
    <p class="trials-sub">Five to earn. Tilt them around — the real ones are laser-cut.</p>
  </header>

  <!-- shared clip for the gloss overlays: same cut path, normalized to the element box -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <clipPath id="cut-bb" clipPathUnits="objectBoundingBox">
        <path transform={`scale(${1 / W}, ${1 / H})`} d={CUT} />
      </clipPath>
    </defs>
  </svg>

  <div class="b3d-grid">
    {BADGES.map((b, i) => (
      <figure class="b3d" data-tilt>
        <div class="b3d-inner">
          <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={`${b.title} badge`}>
            <defs>
              <clipPath id={`cut-${i}`}><path d={CUT} /></clipPath>
            </defs>
            <path d={CUT} fill="#fdfdfd" />
            <image
              href={`/trials/badge-${b.file}.png`}
              x="0" y="0" width={W} height={H}
              clip-path={`url(#cut-${i})`}
            />
          </svg>
          <div class="b3d-gloss" aria-hidden="true"></div>
        </div>
        <figcaption>{b.title}</figcaption>
      </figure>
    ))}
  </div>

  <script is:inline>
    // pointer-tracking 3D tilt + gloss; idle float when untouched
    (function () {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      document.querySelectorAll(".b3d").forEach((card, i) => {
        const inner = card.querySelector(".b3d-inner");
        const gloss = card.querySelector(".b3d-gloss");
        inner.style.animationDelay = (i * -1.3) + "s";
        card.addEventListener("pointermove", (e) => {
          const r = card.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width;
          const y = (e.clientY - r.top) / r.height;
          inner.classList.add("live");
          inner.style.transform =
            "rotateY(" + ((x - 0.5) * 26).toFixed(2) + "deg) " +
            "rotateX(" + ((0.5 - y) * 18).toFixed(2) + "deg) scale(1.04)";
          gloss.style.opacity = "1";
          gloss.style.background =
            "radial-gradient(circle at " + (x * 100).toFixed(1) + "% " + (y * 100).toFixed(1) + "%, rgba(255,255,255,.5), rgba(255,255,255,0) 55%)";
        });
        card.addEventListener("pointerleave", () => {
          inner.classList.remove("live");
          inner.style.transform = "";
          gloss.style.opacity = "0";
        });
      });
    })();
  </script>
</TrialsLayout>

<style>
  .b3d-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 220px));
    gap: 2rem 1.6rem; justify-content: center;
  }
  .b3d { margin: 0; perspective: 800px; }
  .b3d-inner {
    position: relative; transform-style: preserve-3d;
    transition: transform .18s ease-out;
    animation: b3d-float 7s ease-in-out infinite;
    filter: drop-shadow(0 16px 22px rgba(17, 17, 27, .5));
    will-change: transform;
  }
  .b3d-inner.live { animation-play-state: paused; }
  .b3d-inner svg { display: block; width: 100%; height: auto; }
  .b3d-gloss {
    position: absolute; inset: 0; pointer-events: none; opacity: 0;
    transition: opacity .25s; mix-blend-mode: soft-light;
    clip-path: url(#cut-bb);
  }
  @keyframes b3d-float {
    0%, 100% { transform: rotateY(-7deg) rotateX(3deg) translateY(0); }
    50%      { transform: rotateY(7deg) rotateX(-3deg) translateY(-7px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .b3d-inner { animation: none; transition: none; }
  }
  figcaption {
    margin-top: .8rem; text-align: center; font-weight: 600; font-size: .95rem;
    color: var(--subtext1);
  }
</style>
