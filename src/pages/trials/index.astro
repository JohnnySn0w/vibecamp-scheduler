---
// Vibecamp Trials hub — links out to About, Documents, and Hints.
import TrialsLayout from "../../layouts/TrialsLayout.astro";
---

<TrialsLayout
  title="Vibecamp Trials · Vibecamp 5"
  description="The Vibecamp Trials — the camp-wide game running all weekend at Vibecamp 5."
>
  <header class="trials-hero">
    <p class="kicker">✦ Vibe Camp</p>
    <h1><span class="spark" aria-hidden="true">✦</span> Vibecamp Trials <span class="spark s2" aria-hidden="true">✧</span></h1>
    <p class="trials-sub">The camp-wide game · all weekend · June 18–21</p>
  </header>

  <div class="board">
  <nav class="t-cards" aria-label="Trials pages">
    <a class="t-card" href="/trials/about/" style="--ac: var(--peach); --tilt: -1.6deg">
      <span class="t-card-emoji" aria-hidden="true">📜</span>
      <span class="t-card-title">About</span>
      <span class="t-card-desc">How this is going down — shifts, signups, badges, and what to expect.</span>
      <span class="t-card-go" aria-hidden="true">Read up →</span>
    </a>
    <a class="t-card" href="/trials/documents/" style="--ac: var(--sky); --tilt: 1.2deg">
      <span class="t-card-emoji" aria-hidden="true">🗂️</span>
      <span class="t-card-title">Documents</span>
      <span class="t-card-desc">Every handout from signup, posted here so you never lose your copy.</span>
      <span class="t-card-go" aria-hidden="true">Browse →</span>
    </a>
    <a class="t-card" href="/trials/donate/" style="--ac: var(--pink); --tilt: 1.5deg">
      <span class="t-card-emoji" aria-hidden="true">💝</span>
      <span class="t-card-title">Donate</span>
      <span class="t-card-desc">A year in the making and a resource stretcher — help cover the Trials.</span>
      <span class="t-card-go" aria-hidden="true">Chip in →</span>
    </a>
    <a class="t-card" href="/trials/badges/" style="--ac: var(--yellow); --tilt: -1.3deg">
      <span class="t-card-emoji" aria-hidden="true">🛡️</span>
      <span class="t-card-title">The Badges</span>
      <span class="t-card-desc">Five badges to earn — see them rendered in glorious 3D.</span>
      <span class="t-card-go" aria-hidden="true">Behold →</span>
    </a>
  </nav>
  <p class="sticky" aria-hidden="true">the rats are not a metaphor 🐀</p>
  </div>
</TrialsLayout>
